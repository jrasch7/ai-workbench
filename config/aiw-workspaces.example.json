{
  "version": 1,
  "active": "aiw",
  "workspaces": [
    {
      "id": "aiw",
      "name": "AI Workbench",
      "path": "/home/joao/ai-workbench",
      "type": "python",
      "profile": {
        "safe_roots": ["."],
        "source_roots": ["aiw_runtime", "aiw_context", "scripts", "docs"],
        "test_commands": [
          "python3 -m py_compile aiw_runtime/*.py",
          "python3 -m py_compile aiw_context/*.py",
          "bash -n scripts/aiw-cockpit"
