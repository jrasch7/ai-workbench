# Example environment configuration for ai-workbench

# OpenAI API key for OpenHands (replace with your key)
OPENAI_API_KEY=your_openai_api_key_here

# LiteLLM configuration
LITELLM_API_KEY=your_litellm_api_key_here

# OpenRouter API key (optional, for fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model selection (default for OpenHands)
OPENHANDS_MODEL=openai/dev-coder

# Base URL for OpenHands UI (when running locally)
OPENHANDS_BASE_URL=http://host.docker.internal:4000

# LiteLLM alias for the OpenHands model
LITELLM_ALIAS=dev-coder
