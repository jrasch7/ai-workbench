    # Review / Activity sections
    review_runs = [r for r in runs if r["status"] in ("queued", "review")]
    other_runs = [r for r in runs if r["status"] not in ("queued", "review")]

    def mini_run_card(row: dict) -> str:
        cls = classify_run(row)
        title = html.escape(row["title"] if row["title"] != "-" else row["task_id"])
        run_path = html.escape(row["run"])
        filter_flags = [
            "all",
            "legacy" if cls["mode"] == "Legado" else cls["mode"].lower(),
            "tools" if cls["has_tools"] else "",
            "patches" if cls["has_patch_preview"] else "",
            "failed" if cls["failed"] or cls["failed_tool"] else "",
            "applied" if cls["has_patch_apply"] else "",
        ]
        filter_data = " ".join([f for f in filter_flags if f])
        badges = [
            f'<span class="tag status-{html.escape(row["status"])}">{html.escape(row["status"])}</span>',
            f'<span class="tag">Tools {cls["tool_total"]}</span>' if cls["has_tools"] else "",
            f'<span class="tag status-preview">Patches {cls["patches_proposed"]}</span>' if cls["has_patch_preview"] else "",
            '<span class="tag status-applied">Applied</span>' if cls["has_patch_apply"] else "",
            '<span class="tag status-failed">Failed Tool</span>' if cls["failed_tool"] else "",
            '<span class="tag status-failed">Failed</span>' if cls["failed"] else "",
            '<span class="tag status-offline">Offline</span>' if cls["mode"] == "Offline" else "",
            f'<span class="tag">{html.escape(row.get("artifact_scope", "legacy"))}</span>',
        ]
        return f"""
        <div class="mini-run" data-run-filter="{html.escape(filter_data)}">
          <div class="mini-run-title"><a href="/run?path={quote(row['run'])}">{title}</a></div>
          <div class="mini-run-meta">{''.join(b for b in badges if b)}</div>
          <div class="card-doc" style="margin-top:7px;margin-bottom:0">{run_path}</div>
        </div>
        """

    def harness_column(label: str, rows: list[dict], empty: str) -> str:
        body = "".join(mini_run_card(r) for r in rows[:6]) if rows else f'<div class="empty-state" style="padding:20px 12px">{empty}</div>'
        return f"""
        <div class="harness-column">
          <h4>{html.escape(label)}</h4>
          {body}
        </div>
        """

    online_runs = [r for r in runs if classify_run(r)["mode"] == "Online"]
    offline_runs = [r for r in runs if classify_run(r)["mode"] == "Offline"]
    legacy_runs = [r for r in runs if classify_run(r)["mode"] == "Legado"]
