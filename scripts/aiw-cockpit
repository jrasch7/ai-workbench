    def patch_item(patch: dict) -> str:
        pid = html.escape(patch["patch_id"])
        short_pid = html.escape(patch["patch_id"][:17])
        status = html.escape(patch["status"])
        path_value = html.escape(patch["path"] or "-")
        reason = html.escape(patch["reason"] or "Sem motivo registrado.")
        diff = html.escape(patch["diff"] or "")
        run_assoc = html.escape(patch["run_id"] or "sem run associado")
        created = html.escape(patch.get("created_at") or "-")
        scope = html.escape(patch.get("artifact_scope") or "legacy")
        ws_id = html.escape(patch.get("workspace_id") or active_workspace)
        diff_stats = html.escape(diff_summary(patch["diff"]))
        apply_btn = ""
        if patch["status"] == "preview":
            apply_btn = f'''<form method="post" action="/runner/patch/apply"><input type="hidden" name="patch_id" value="{pid}"><button class="btn btn-run" type="submit">Aplicar</button></form>'''
        elif patch["status"] == "applied":
            apply_btn = f'''<form method="post" action="/runner/patch/rollback"><input type="hidden" name="patch_id" value="{pid}"><button class="btn btn-danger" type="submit">Rollback</button></form>'''
        return f"""
        <div class="patch-item" data-patch-filter="{status}">
          <div class="patch-head">
            <div>
              <div class="patch-path">{path_value}</div>
              <div class="card-doc" style="margin:4px 0 0">{short_pid} · {run_assoc}</div>
            </div>
            <span class="tag status-{status}">{status}</span>
          </div>
          <div class="patch-reason">{reason}</div>
          <div class="card-meta">
            <span class="tag">{created}</span>
            <span class="tag">{diff_stats}</span>
            <span class="tag">{ws_id}</span>
            <span class="tag">{scope}</span>
          </div>
          <details>
            <summary style="cursor:pointer;color:var(--muted);font-size:12px">Unified diff log</summary>
            <pre style="margin-top:8px;background:var(--bg);border-radius:8px">{diff}</pre>
          </details>
          <div class="patch-actions">{apply_btn}</div>
        </div>
        """

    patches_panel = "".join(patch_item(p) for p in patch_proposals)
