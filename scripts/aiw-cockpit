def count_tasks(queue: str) -> int:
    path = ROOT / ".aiw" / "tasks" / queue
    if not path.exists():
        return 0
    return len([p for p in path.glob("*.md") if p.is_file()])


def read_json(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {"status": "invalid_json"}


def read_task_id(run_dir: Path) -> str:
    task = run_dir / "task.md"
    if not task.exists():
        return "-"
    for line in task.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.startswith("Task ID:"):
            return line.split(":", 1)[1].strip() or "-"
    return "-"


def read_task_title(run_dir: Path) -> str:
    task = run_dir / "task.md"
    if not task.exists():
        return "-"
    for line in task.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.startswith("# "):
            return line[2:].strip() or "-"
    return "-"


def read_summary_first_lines(run_dir: Path, lines: int = 3) -> str:
    summary = run_dir / "summary.md"
    if not summary.exists():
        return ""
    text = summary.read_text(encoding="utf-8", errors="replace")
    parts = [l for l in text.splitlines() if l.strip()]
    return " ".join(parts[:lines])


def list_runs(limit: int = 25, workspace_id: str | None = None) -> list[dict]:
    workspace_id = active_workspace_id(workspace_id)
    rows = []
    seen = set()
    for scope, runs_dir in workspace_runs_dirs(ROOT, workspace_id):
        if not runs_dir.exists():
            continue
        for run in [p for p in runs_dir.iterdir() if p.is_dir()]:
            if run.resolve() in seen:
                continue
            seen.add(run.resolve())
            status = read_json(run / "status.json")
            rows.append({
                "run": str(run.relative_to(ROOT)),
                "task_id": read_task_id(run),
                "title": read_task_title(run),
                "status": status.get("status", "unknown"),
                "llm_status": status.get("llm_status", "-"),
                "doc_status": status.get("doc_status", "-"),
                "generated_file": status.get("generated_file", ""),
                "model": status.get("model", "-"),
                "summary": read_summary_first_lines(run),
                "workspace_id": status.get("workspace_id", workspace_id),
                "artifact_scope": status.get("artifact_scope", scope),
            })
    rows.sort(key=lambda row: row["run"], reverse=True)
    return rows[:limit]


def short_git_head() -> str:
    try:
        proc = subprocess.run(
            ["git", "rev-parse", "--short", "HEAD"],
            cwd=ROOT,
            capture_output=True,
            text=True,
            timeout=2,
        )
        head = proc.stdout.strip()
        return head or "-"
    except Exception:
        return "-"


def current_git_branch() -> str:
    try:
        proc = subprocess.run(
            ["git", "branch", "--show-current"],
            cwd=ROOT,
            capture_output=True,
            text=True,
            timeout=2,
        )
        branch = proc.stdout.strip()
        return branch or "-"
    except Exception:
        return "-"


WORKSPACES_CONFIG = ROOT / ".aiw" / "workspaces.json"
DEFAULT_WORKSPACE = {
    "id": "aiw",
    "name": "AI Workbench",
    "path": str(ROOT),
    "type": "aiw",
}
SAFE_BRANCH_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._/-]{0,79}$")
FORBIDDEN_GIT_PARTS = (
    ".env",
    "secret",
    "token",
    "credential",
    "private_key",
    "client_secret",
    "AGENTS.md",
    ".aiw/context/",
    ".aiw/runs/",
    ".aiw/backups/",
    ".aiw/generated/",
    ".aiw/patches/",
    ".aiw/workspaces/",
)


def git_run(cwd: Path, args: list[str], timeout: int = 10) -> subprocess.CompletedProcess:
    return subprocess.run(
        ["git", *args],
        cwd=cwd,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def load_workspaces_config() -> dict:
    return load_workspace_profiles()


def resolve_workspace(workspace_id: str) -> dict | None:
    return resolve_workspace_profile(workspace_id)


def workspace_health(workspace_id: str) -> dict:
    ws = resolve_workspace(workspace_id)
    if not ws:
        return {"ok": False, "error": "unknown_workspace"}
    path = Path(ws["resolved_path"])
    health = {
        "ok": True,
        "id": ws["id"],
        "name": ws["name"],
        "path": str(path),
        "type": ws.get("type", "external"),
        "exists": path.is_dir(),
        "branch": "-",
        "head": "-",
        "dirty": False,
        "modified_count": 0,
        "readme": False,
        "docs": False,
        "package_json": False,
        "pyproject": False,
        "last_commit": "-",
        "execution_enabled": ws.get("execution_enabled", path.is_dir()),
        "profile": ws.get("profile", {}),
    }
    if not path.is_dir():
        return health
    health["readme"] = (path / "README.md").is_file()
    health["docs"] = (path / "docs").is_dir()
    health["package_json"] = (path / "package.json").is_file()
    health["pyproject"] = (path / "pyproject.toml").is_file()
    try:
        health["branch"] = git_run(path, ["branch", "--show-current"]).stdout.strip() or "-"
        health["head"] = git_run(path, ["rev-parse", "--short", "HEAD"]).stdout.strip() or "-"
        status_lines = git_status_files(path)
        health["dirty"] = bool(status_lines)
        health["modified_count"] = len(status_lines)
        health["last_commit"] = git_run(path, ["log", "-1", "--oneline"]).stdout.strip() or "-"
    except Exception as exc:
        health["git_error"] = str(exc)
    return health


def workspaces_payload() -> dict:
    config = load_workspaces_config()
    return {
        "active": config.get("active", "aiw"),
        "config_path": str(WORKSPACES_CONFIG),
        "local_config_exists": WORKSPACES_CONFIG.exists(),
        "workspaces": [workspace_health(ws["id"]) for ws in config["workspaces"]],
    }


def write_active_workspace(workspace_id: str) -> dict:
    ws = resolve_workspace(workspace_id)
    if not ws:
        return {"ok": False, "error": "unknown_workspace"}
    if not ws["exists"]:
        return {"ok": False, "error": "workspace_path_missing"}
    config = load_workspaces_config()
    config["active"] = workspace_id
    WORKSPACES_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    WORKSPACES_CONFIG.write_text(json.dumps(config, indent=2), encoding="utf-8")
    return {"ok": True, "active": workspace_id}


def workspace_path_or_error(workspace_id: str) -> tuple[Path | None, dict | None]:
    ws = resolve_workspace(workspace_id or "aiw")
    if not ws:
        return None, {"ok": False, "error": "unknown_workspace"}
    path = Path(ws["resolved_path"])
    if not path.is_dir():
        return None, {"ok": False, "error": "workspace_path_missing"}
    return path, None


def active_workspace_id(workspace_id: str | None = None) -> str:
    if workspace_id:
        ws = resolve_workspace(workspace_id)
        return ws["id"] if ws else "aiw"
    env_ws = os.environ.get("AIW_WORKSPACE_ID", "").strip()
    if env_ws:
        return normalize_workspace_id(env_ws)
    return normalize_workspace_id(load_workspaces_config().get("active", "aiw"))


def workspace_root_for_context(workspace_id: str | None = None) -> Path:
    ws = resolve_workspace(active_workspace_id(workspace_id))
    if ws and ws.get("exists"):
        return Path(ws["resolved_path"])
    return ROOT


def artifact_scope_label(path: Path, workspace_id: str | None = None) -> str:
    ws_id = active_workspace_id(workspace_id)
    scoped_base = (ROOT / ".aiw" / "workspaces" / ws_id).resolve()
    try:
        path.resolve().relative_to(scoped_base)
        return "scoped"
    except ValueError:
        return "legacy"


def iter_artifact_dirs(kind: str, workspace_id: str | None = None) -> list[tuple[str, Path]]:
    ws_id = active_workspace_id(workspace_id)
    if kind == "runs":
        return workspace_runs_dirs(ROOT, ws_id)
    if kind == "patches":
        return workspace_patches_dirs(ROOT, ws_id)
    return []


def git_status_files(path: Path) -> list[dict]:
    proc = git_run(path, ["status", "--porcelain"], timeout=10)
    files = []
    for line in proc.stdout.splitlines():
        if not line:
            continue
        status = line[:2].strip() or "?"
        file_path = line[3:] if len(line) > 3 else line
        if " -> " in file_path:
            file_path = file_path.split(" -> ", 1)[1]
        files.append({"status": status, "path": file_path})
    return files


def is_forbidden_git_file(file_path: str) -> bool:
    normalized = file_path.replace("\\", "/").lstrip("/")
    lower = normalized.lower()
    if normalized == "AGENTS.md":
        return True
    return any(part.lower() in lower for part in FORBIDDEN_GIT_PARTS)


def validate_git_file_selection(path: Path, files: list[str]) -> tuple[list[str], str]:
    if not files:
        return [], "no_files_selected"
    changed = {f["path"] for f in git_status_files(path)}
    allowed = []
    for raw in files:
        file_path = str(raw).strip()
        if not file_path or file_path.startswith("/") or ".." in Path(file_path).parts:
            return [], f"invalid_file:{file_path}"
        if is_forbidden_git_file(file_path):
            return [], f"forbidden_file:{file_path}"
        if file_path not in changed:
            return [], f"file_not_changed:{file_path}"
        allowed.append(file_path)
    return allowed, ""


def git_status_payload(workspace_id: str) -> dict:
    path, err = workspace_path_or_error(workspace_id)
    if err:
        return err
    files = git_status_files(path)
    return {
        "ok": True,
        "workspace": workspace_id,
        "branch": git_run(path, ["branch", "--show-current"]).stdout.strip() or "-",
        "head": git_run(path, ["rev-parse", "--short", "HEAD"]).stdout.strip() or "-",
        "dirty": bool(files),
        "files": files,
    }


def git_diff_payload(workspace_id: str) -> dict:
    path, err = workspace_path_or_error(workspace_id)
    if err:
        return err
    stat = git_run(path, ["diff", "--stat"]).stdout.strip()
    names = git_run(path, ["diff", "--name-only"]).stdout.strip().splitlines()
    cached = git_run(path, ["diff", "--cached", "--name-only"]).stdout.strip().splitlines()
    return {"ok": True, "workspace": workspace_id, "stat": stat, "files": names, "staged_files": cached}


def validate_branch_name(name: str) -> bool:
    if not name or not SAFE_BRANCH_RE.match(name):
        return False
    if name.endswith("/") or "//" in name or ".." in name or "@{" in name:
        return False
    return True


def list_patch_proposals(limit: int = 30, workspace_id: str | None = None) -> list[dict]:
    workspace_id = active_workspace_id(workspace_id)
    proposals = []
    seen = set()
    for scope, patches_dir in iter_artifact_dirs("patches", workspace_id):
        if not patches_dir.exists():
            continue
        for patch_file in sorted(patches_dir.glob("*.json"), reverse=True):
            data = read_json(patch_file)
            if not isinstance(data, dict):
                continue
            patch_id = str(data.get("patch_id") or patch_file.stem)
            if patch_id in seen:
                continue
            seen.add(patch_id)
            proposals.append({
                "patch_id": patch_id,
                "path": str(data.get("path", "")),
                "status": str(data.get("status", "unknown")),
                "reason": str(data.get("reason", "")),
                "diff": str(data.get("diff", "")),
                "run_id": str(data.get("run_id") or data.get("run_path") or ""),
                "created_at": str(data.get("created_at", "")),
                "workspace_id": str(data.get("workspace_id", workspace_id)),
                "artifact_scope": str(data.get("artifact_scope", scope)),
            })
    proposals.sort(key=lambda row: row.get("created_at") or row["patch_id"], reverse=True)
    return proposals[:limit]


def diff_summary(diff_text: str) -> str:
    if not diff_text:
        return "Sem diff registrado."
    added = 0
    removed = 0
    for line in diff_text.splitlines():
        if line.startswith("+") and not line.startswith("+++"):
            added += 1
        elif line.startswith("-") and not line.startswith("---"):
            removed += 1
    return f"+{added} / -{removed} linhas"


SENSITIVE_FIELD_PARTS = ("key", "token", "secret", "password", "api_key")
SENSITIVE_VALUE_PARTS = (".env", "litellm_master_key", "api_key", "client_secret", "private_key")


def is_sensitive_name(name: object) -> bool:
    lower = str(name).lower()
    return any(part in lower for part in SENSITIVE_FIELD_PARTS)


def mask_text(value: object, limit: int = 900) -> str:
    text = "" if value is None else str(value)
    lower = text.lower()
    if any(part in lower for part in SENSITIVE_VALUE_PARTS):
        return "[masked]"
    if len(text) > limit:
        return text[:limit].rstrip() + "..."
    return text


def sanitize_ui_text(value: object) -> str:
    text = "" if value is None else str(value)
    replacements = {
        ".env": "[masked-env]",
        "LITELLM_MASTER_KEY": "[masked-key]",
        "litellm_master_key": "[masked-key]",
        "api_key": "[masked-key]",
        "client_secret": "[masked-secret]",
        "private_key": "[masked-secret]",
    }
    for old, new in replacements.items():
        text = text.replace(old, new)
    return text


def mask_payload(value):
    if isinstance(value, dict):
        masked = {}
        for key, item in value.items():
            if is_sensitive_name(key):
                masked[key] = "[masked]"
            else:
                masked[key] = mask_payload(item)
        return masked
    if isinstance(value, list):
        return [mask_payload(item) for item in value[:80]]
    if isinstance(value, str):
        return mask_text(value, limit=1400)
    return value


def safe_json_text(value, limit: int = 1600) -> str:
    try:
        text = json.dumps(mask_payload(value), ensure_ascii=False, indent=2)
    except Exception:
        text = mask_text(value, limit=limit)
    return mask_text(text, limit=limit)


def parse_tool_arguments(raw_args) -> dict:
    if isinstance(raw_args, dict):
        return mask_payload(raw_args)
    if not raw_args:
        return {}
    try:
        parsed = json.loads(raw_args)
        return mask_payload(parsed if isinstance(parsed, dict) else {"value": parsed})
    except Exception:
        return {"raw": mask_text(raw_args, limit=600)}


def summarize_input(tool_name: str, args: dict) -> str:
    path = args.get("path")
    if path:
        return f"Arquivo: {mask_text(path, limit=120)}"
    command = args.get("command")
    if command:
        return f"Comando seguro: {mask_text(command, limit=160)}"
    if tool_name == "directory_list":
        return "Listagem de diretório"
    return safe_json_text(args, limit=240) if args else "Sem entrada registrada"


def summarize_output(tool_name: str, result: dict) -> str:
    if not isinstance(result, dict):
        return mask_text(result, limit=300)
    if result.get("error"):
        return mask_text(result.get("error"), limit=300)
    if tool_name == "file_read":
        content = result.get("content", "")
        return f"Leu {len(str(content).encode('utf-8'))} bytes. Trecho: {mask_text(content, limit=220)}"
    if tool_name == "directory_list":
        entries = result.get("entries", [])
        return f"Listou {len(entries)} entradas."
    if tool_name == "shell_exec":
        stdout = mask_text(result.get("stdout", ""), limit=220)
        stderr = mask_text(result.get("stderr", ""), limit=220)
        parts = [f"Exit code: {result.get('exit_code', '-')}"]
        if stdout:
            parts.append(f"stdout: {stdout}")
        if stderr:
            parts.append(f"stderr: {stderr}")
        return " | ".join(parts)
    if tool_name == "project_patch_preview":
        return f"Patch {result.get('status', 'preview')} para {mask_text(result.get('path', ''), limit=140)}."
    if tool_name in ("project_patch_apply", "project_patch_rollback"):
        return f"Patch {result.get('patch_id', '-')} -> {result.get('status', '-')}"
    diff = result.get("diff")
    if diff:
        return mask_text(diff, limit=260)
    return safe_json_text(result, limit=320)


def patch_status_for_id(patch_id: str, workspace_id: str | None = None) -> dict:
    if not patch_id:
        return {}
    for scope, patches_dir in iter_artifact_dirs("patches", workspace_id):
        patch_file = patches_dir / f"{patch_id}.json"
        if patch_file.exists():
            data = read_json(patch_file)
            if isinstance(data, dict):
                data.setdefault("artifact_scope", scope)
                data.setdefault("workspace_id", active_workspace_id(workspace_id))
                return mask_payload(data)
    return {}


def build_tool_evidence(run_dir: Path) -> dict:
    traces_file = run_dir / "tool-traces.jsonl"
    status_data = read_json(run_dir / "status.json")
    tools = []
    invalid_lines = 0

    if traces_file.exists():
        for line in traces_file.read_text(encoding="utf-8", errors="replace").splitlines():
            if not line.strip():
                continue
            try:
                raw = json.loads(line)
            except Exception:
                invalid_lines += 1
                continue

            call = raw.get("call", {}) if isinstance(raw, dict) else {}
            func = call.get("function", {}) if isinstance(call, dict) else {}
            result = raw.get("result", {}) if isinstance(raw, dict) else {}
            if "event" in raw and not func:
                name = str(raw.get("event", "event"))
                args = {"event": raw.get("event"), "evidence": raw.get("evidence", [])}
                result = {"ok": bool(raw.get("ok", False)), "tool": name, "run_id": raw.get("run_id")}
            else:
                name = str(func.get("name") or (result.get("tool") if isinstance(result, dict) else "") or "unknown")
                args = parse_tool_arguments(func.get("arguments", {}))

            result = mask_payload(result if isinstance(result, dict) else {"value": result})
            ok = bool(result.get("ok", False))
            patch_id = str(result.get("patch_id", "") or "")
            patch_data = patch_status_for_id(patch_id)
            patch_status = str(patch_data.get("status") or result.get("status") or "")

            tools.append({
                "name": name,
                "ok": ok,
                "status": "sucesso" if ok else "erro",
                "args": args,
                "input_summary": summarize_input(name, args),
                "output_summary": summarize_output(name, result),
                "error": mask_text(result.get("error", ""), limit=300),
                "result": result,
                "raw": mask_payload(raw),
                "patch_id": patch_id,
                "patch_status": patch_status,
                "patch_path": str(patch_data.get("path") or result.get("path") or args.get("path") or ""),
                "patch_reason": str(patch_data.get("reason") or args.get("reason") or ""),
                "diff": str(patch_data.get("diff") or result.get("diff") or ""),
            })

    patches_proposed = len([t for t in tools if t["name"] == "project_patch_preview" and t.get("patch_id")])
    patches_applied = len([t for t in tools if t["name"] == "project_patch_apply" or t.get("patch_status") == "applied"])
    failed_tools = len([t for t in tools if not t["ok"]])
    is_offline = bool(status_data.get("offline")) or status_data.get("mode") == "offline" or any(t["name"] == "offline_dry_run" for t in tools)
    mode = "offline" if is_offline else ("online" if traces_file.exists() else "legacy")

    return {
        "run": str(run_dir.relative_to(ROOT)),
        "mode": mode,
        "total": len(tools),
        "successes": len(tools) - failed_tools,
        "failures": failed_tools,
        "patches_proposed": patches_proposed,
        "patches_applied": patches_applied,
        "invalid_lines": invalid_lines,
        "tools": tools,
    }


def render_tool_evidence_block(evidence: dict, rel: str) -> str:
    metrics = f"""
    <div class="evidence-summary">
      <div class="evidence-metric"><span>Modo</span><strong>{html.escape(evidence["mode"])}</strong></div>
      <div class="evidence-metric"><span>Total</span><strong>{evidence["total"]}</strong></div>
      <div class="evidence-metric"><span>Sucessos</span><strong>{evidence["successes"]}</strong></div>
      <div class="evidence-metric"><span>Falhas</span><strong>{evidence["failures"]}</strong></div>
      <div class="evidence-metric"><span>Patches</span><strong>{evidence["patches_proposed"]}</strong></div>
      <div class="evidence-metric"><span>Aplicados</span><strong>{evidence["patches_applied"]}</strong></div>
    </div>
    """

    cards = ""
    for tool in evidence["tools"]:
        status_cls = "status-done" if tool["ok"] else "status-failed"
        status_lbl = "sucesso" if tool["ok"] else "erro"
        raw_json = safe_json_text(tool.get("raw", {}), limit=3000)
        result_json = safe_json_text(tool.get("result", {}), limit=2200)
        patch_actions = ""
        if tool["name"] == "project_patch_preview" and tool.get("patch_id"):
            pid = html.escape(tool["patch_id"])
            patch_status = tool.get("patch_status") or "preview"
            if patch_status == "preview":
                patch_actions = f'''<form method="post" action="/runner/patch/apply" style="display:inline"><input type="hidden" name="patch_id" value="{pid}"><input type="hidden" name="run_path" value="{html.escape(rel)}"><button class="btn btn-run" style="padding:6px 10px;font-size:12px" type="submit">Aplicar</button></form>'''
            elif patch_status == "applied":
                patch_actions = f'''<form method="post" action="/runner/patch/rollback" style="display:inline"><input type="hidden" name="patch_id" value="{pid}"><input type="hidden" name="run_path" value="{html.escape(rel)}"><button class="btn btn-danger" style="padding:6px 10px;font-size:12px" type="submit">Rollback</button></form>'''

        patch_line = ""
        if tool["name"].startswith("project_patch") or tool.get("patch_id"):
            patch_line = f"""
            <div class="tool-evidence-field">
              <strong>Patch</strong>
              {html.escape(tool.get("patch_path") or "-")} · {html.escape(tool.get("patch_status") or "-")}
              <div style="margin-top:6px">{patch_actions}</div>
            </div>
            """

        cards += f"""
        <div class="tool-evidence-card">
          <div class="tool-evidence-head">
            <div>
              <div class="tool-evidence-title">Tool: {html.escape(tool["name"])}</div>
              <div class="tool-evidence-sub">{html.escape(tool.get("patch_reason") or tool["input_summary"])}</div>
            </div>
            <span class="tag {status_cls}">{status_lbl}</span>
          </div>
          <div class="tool-evidence-grid">
            <div class="tool-evidence-field"><strong>Entrada</strong>{html.escape(tool["input_summary"])}</div>
            <div class="tool-evidence-field"><strong>Resultado</strong>{html.escape(tool["output_summary"])}</div>
            {patch_line}
            <div class="tool-evidence-field"><strong>Erro</strong>{html.escape(tool["error"] or "-")}</div>
          </div>
          <details style="margin-top:10px">
            <summary style="cursor:pointer;color:var(--muted);font-size:12px">Avançado</summary>
            <div style="margin-top:8px">
              <div class="tool-evidence-sub" style="margin-bottom:4px">Resultado sanitizado</div>
              <pre style="border-radius:8px;background:var(--bg);margin-bottom:8px">{html.escape(result_json)}</pre>
              <div class="tool-evidence-sub" style="margin-bottom:4px">Raw técnico sanitizado</div>
              <pre style="border-radius:8px;background:var(--bg)">{html.escape(raw_json)}</pre>
            </div>
          </details>
        </div>
        """

    if not cards:
        cards = '<div class="empty-state">Nenhuma ferramenta usada neste run.</div>'

    invalid_note = ""
    if evidence.get("invalid_lines"):
        invalid_note = f'<div class="signal-note">Linhas inválidas ignoradas: {evidence["invalid_lines"]}</div>'

    return f"""
    <div class="priority-block">
      <h3>Evidências das ferramentas</h3>
      {metrics}
      <div class="tool-evidence-list">{cards}</div>
      {invalid_note}
    </div>
    """


def build_run_timeline(run_dir: Path, evidence: dict) -> list[dict]:
    status = read_json(run_dir / "status.json")
    events = []

    created = status.get("created_at") or status.get("started_at") or ""
    if (run_dir / "task.md").exists():
        events.append({
            "type": "task",
            "time": created,
            "status": "ok",
            "summary": "Tarefa criada",
            "raw": {"task_id": read_task_id(run_dir), "title": read_task_title(run_dir)},
        })

    if status.get("started_at") or status.get("model"):
        events.append({
            "type": "model",
            "time": status.get("started_at", ""),
            "status": "ok" if status.get("llm_status", "") not in ("failed", "error") else "erro",
            "summary": f"Modelo iniciado: {status.get('model', '-')}",
            "raw": mask_payload({"model": status.get("model"), "llm_status": status.get("llm_status")}),
        })

    messages_file = run_dir / "messages.json"
    if messages_file.exists():
        msgs = read_json(messages_file)
        if isinstance(msgs, list):
            for msg in msgs:
                role = msg.get("role", "")
                if role == "assistant" and msg.get("tool_calls"):
                    events.append({
                        "type": "model",
                        "time": msg.get("created_at", ""),
                        "status": "ok",
                        "summary": "Modelo solicitou ferramentas",
                        "raw": mask_payload(msg),
                    })

    for tool in evidence.get("tools", []):
        name = tool["name"]
        if name == "project_patch_preview":
            summary = "Patch proposto"
            event_type = "patch"
        elif name == "project_patch_apply":
            summary = "Patch aplicado"
            event_type = "patch"
        elif name == "project_patch_rollback":
            summary = "Patch revertido"
            event_type = "patch"
        elif name == "offline_dry_run":
            summary = "Run offline validado"
            event_type = "offline"
        else:
            summary = f"Tool executada: {name}"
            event_type = "tool"
        events.append({
            "type": event_type,
            "time": "",
            "status": "ok" if tool.get("ok") else "erro",
            "summary": summary,
            "raw": tool.get("raw", {}),
        })

    final_status = status.get("status", "")
    if final_status:
        final_summary = "Execução finalizada"
        if final_status in ("failed", "timed_out") or "failed" in str(final_status):
            final_summary = "Falha upstream / timeout"
        events.append({
            "type": "finish",
            "time": status.get("finished_at", ""),
            "status": final_status,
            "summary": final_summary,
            "raw": mask_payload(status),
        })

    if not events and (run_dir / "summary.md").exists():
        events.append({
            "type": "summary",
            "time": "",
            "status": "ok",
            "summary": "Resumo disponível",
            "raw": {"summary": read_summary_first_lines(run_dir)},
        })

    return events


def render_run_timeline_block(events: list[dict]) -> str:
    if not events:
        return """
        <div class="priority-block">
          <h3>Timeline do run</h3>
          <div class="empty-state">Nenhum evento encontrado para este run.</div>
        </div>
        """

    items = ""
    for event in events:
        status = html.escape(str(event.get("status") or "-"))
        status_cls = "status-done" if status in ("ok", "review", "succeeded", "succeeded_offline") else ("status-failed" if status in ("erro", "failed", "timed_out") else "status-running")
        raw = safe_json_text(event.get("raw", {}), limit=1800)
        time_line = html.escape(str(event.get("time") or "sem horário registrado"))
        items += f"""
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-body">
            <div class="timeline-head">
              <strong>{html.escape(event.get("summary", "-"))}</strong>
              <span class="tag {status_cls}">{status}</span>
            </div>
            <div class="timeline-meta">{html.escape(event.get("type", "-"))} · {time_line}</div>
            <details>
              <summary style="cursor:pointer;color:var(--muted);font-size:12px">Avançado</summary>
              <pre style="margin-top:8px;border-radius:8px;background:var(--bg)">{html.escape(raw)}</pre>
            </details>
          </div>
        </div>
        """

    return f"""
    <div class="priority-block">
      <h3>Timeline do run</h3>
      <div class="timeline-list">{items}</div>
    </div>
    """


def run_has_tool(run_dir: Path, tool_name: str) -> bool:
    traces = run_dir / "tool-traces.jsonl"
    if not traces.exists():
        return False
    try:
        return tool_name in traces.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return False


def classify_run(row: dict) -> dict:
    run_dir = ROOT / row["run"]
    status_data = read_json(run_dir / "status.json")
    status = str(row.get("status", "unknown")).lower()
    evidence = build_tool_evidence(run_dir)
    has_tools = evidence["total"] > 0 or (run_dir / "tool-traces.jsonl").exists()
    is_offline = bool(status_data.get("offline")) or status_data.get("mode") == "offline" or "offline" in status
    has_patch_preview = evidence["patches_proposed"] > 0 or run_has_tool(run_dir, "project_patch_preview")
    has_patch_apply = evidence["patches_applied"] > 0 or run_has_tool(run_dir, "project_patch_apply")
    failed = status in ("failed", "rejected", "cancelled", "timed_out") or "failed" in status
    failed_tool = evidence["failures"] > 0

    if is_offline:
        mode = "Offline"
    elif has_tools:
        mode = "Online"
    else:
        mode = "Legado"

    return {
        "mode": mode,
        "has_tools": has_tools,
        "has_patch_preview": has_patch_preview,
        "has_patch_apply": has_patch_apply,
        "failed": failed,
        "failed_tool": failed_tool,
        "tool_total": evidence["total"],
        "patches_proposed": evidence["patches_proposed"],
        "patches_applied": evidence["patches_applied"],
    }



def local_lexical_search(query: str, workspace_id: str | None = None) -> list[dict]:
    results = []
    q_lower = query.lower()
    workspace_id = active_workspace_id(workspace_id)

    def add_res(rtype, title, label, snip, url, score):
        if SENSITIVE_VALUE_PARTS and any(s in snip.lower() for s in SENSITIVE_VALUE_PARTS):
            snip = mask_text(snip)
        results.append({
            "type": rtype, "title": title, "path_label": label,
            "snippet": mask_text(snip, 150), "url": url, "score": score
        })

    # Search runs (summary.md, tool-traces.jsonl, commands.log)
    for scope, runs_dir in iter_artifact_dirs("runs", workspace_id):
        if not runs_dir.exists():
            continue
        for run_path in runs_dir.iterdir():
            if not run_path.is_dir(): continue
            rel_run = str(run_path.relative_to(ROOT))
            score = 0
            snip = ""
            title = read_task_title(run_path)

            if q_lower in title.lower(): score += 10

            for fname in ["summary.md", "tool-traces.jsonl", "commands.log"]:
                fpath = run_path / fname
                if fpath.exists():
                    try:
                        c = fpath.read_text(encoding="utf-8", errors="replace")
                        idx = c.lower().find(q_lower)
                        if idx >= 0:
                            score += 5
                            if not snip:
                                snip = c[max(0, idx-40):idx+100].replace("\n", " ")
                    except Exception:
                        pass
            if score > 0:
                add_res("run", title, f"Run {run_path.name} · {scope}", snip or "...", f"/run?path={quote(rel_run)}", score)

    # Search tasks
    tasks_dir = ROOT / ".aiw" / "tasks"
    if tasks_dir.exists():
        for queue in TASK_QUEUES:
            q_dir = tasks_dir / queue
            if q_dir.exists():
                for tpath in q_dir.glob("*.md"):
                    score = 0
                    try:
                        c = tpath.read_text(encoding="utf-8", errors="replace")
                        if q_lower in tpath.name.lower(): score += 10
                        idx = c.lower().find(q_lower)
                        if idx >= 0:
                            score += 5
                            snip = c[max(0, idx-40):idx+100].replace("\n", " ")
                            add_res("task", tpath.name, f"Task {queue}", snip, "/", score)
                    except Exception: pass

    # Search patches
    for scope, patches_dir in iter_artifact_dirs("patches", workspace_id):
        if not patches_dir.exists():
            continue
        for ppath in patches_dir.glob("*.json"):
            try:
                data = read_json(ppath)
                if not isinstance(data, dict): continue
                score = 0
                if q_lower in ppath.name.lower(): score += 10
                p_path = str(data.get("path","")).lower()
                if q_lower in p_path: score += 5
                reason = str(data.get("reason",""))
                idx = reason.lower().find(q_lower)
                snip = ""
                if idx >= 0:
                    score += 5
                    snip = reason[max(0, idx-40):idx+100]
                diff = str(data.get("diff",""))
                idx2 = diff.lower().find(q_lower)
                if idx2 >= 0:
                    score += 5
                    if not snip: snip = diff[max(0, idx2-40):idx2+100]
                if score > 0:
                    add_res("patch", f"Patch {ppath.stem}", f"Patch · {scope}", snip, "/", score)
            except Exception: pass

    # Search docs and README
    docs_to_search = [ROOT / "README.md"]
    docs_dir = ROOT / "docs"
    if docs_dir.exists():
        docs_to_search.extend(docs_dir.rglob("*.md"))

    for dpath in docs_to_search:
        if not dpath.is_file(): continue
        if dpath.name.startswith("."): continue
        score = 0
        try:
            if q_lower in dpath.name.lower(): score += 10
            c = dpath.read_text(encoding="utf-8", errors="replace")
            idx = c.lower().find(q_lower)
            if idx >= 0:
                score += 5
                snip = c[max(0, idx-40):idx+100].replace("\n", " ")
                add_res("doc", dpath.name, str(dpath.relative_to(ROOT)), snip, "/", score)
        except Exception: pass

    results.sort(key=lambda x: x["score"], reverse=True)
    return results[:50]


def context_health(workspace_id: str | None = None) -> dict:
    workspace_id = active_workspace_id(workspace_id)
    target_root = workspace_root_for_context(workspace_id)
    docs_dir = target_root / "docs"
    runbooks_dir = target_root / "docs" / "runbooks"
    architecture_dir = target_root / "docs" / "architecture"
    roadmap_dir = target_root / "docs" / "roadmap"
    model_bench_dir = target_root / "docs" / "model-bench"
    docs_count = len(list(docs_dir.rglob("*.md"))) if docs_dir.is_dir() else 0
    runbook_files = sorted(runbooks_dir.glob("*.md"), key=lambda p: p.stat().st_mtime, reverse=True) if runbooks_dir.is_dir() else []
    arch_files = list(architecture_dir.glob("*.md")) if architecture_dir.is_dir() else []
    roadmap_files = list(roadmap_dir.glob("*.md")) if roadmap_dir.is_dir() else []
    script_checks = [
        "scripts/aiw-cockpit",
        "scripts/aiw-runner-agent",
        "scripts/aiw-tool-smoke",
        "scripts/aiw-task-create",
        "scripts/aiw-runner-once",
    ]
    runs = []
    for scope, runs_dir in iter_artifact_dirs("runs", workspace_id):
        if runs_dir.exists():
            runs.extend([p for p in runs_dir.iterdir() if p.is_dir()])
    runs = sorted(runs, reverse=True)

    last_offline = "-"
    last_online = "-"
    for run in runs:
        evidence = build_tool_evidence(run)
        status = read_json(run / "status.json").get("status", "unknown")
        label = f"{run.name}: {status}"
        if evidence["mode"] == "offline" and last_offline == "-":
            last_offline = label
        elif evidence["mode"] == "online" and last_online == "-":
            last_online = label
        if last_offline != "-" and last_online != "-":
            break

    checks_ok = [
        (target_root / "README.md").is_file(),
        docs_dir.is_dir(),
        runbooks_dir.is_dir(),
        bool(arch_files),
        (target_root / "docs" / "MODEL_STRATEGY.md").is_file() or workspace_id != "aiw",
        (target_root / "config" / "litellm.yaml").is_file() or workspace_id != "aiw",
        (target_root / "aiw_runtime").is_dir() or workspace_id != "aiw",
        all((ROOT / s).is_file() for s in script_checks),
    ]
    score = sum(1 for ok in checks_ok if ok)

    idx = get_search_index(target_root, workspace_id)
    if idx:
        indexable_docs = idx.get("document_count", 0)
        indexable_runs = len([d for d in idx.get("documents", []) if d["type"] == "run"])
        indexable_patches = len([d for d in idx.get("documents", []) if d["type"] == "patch"])
        last_index_update = idx.get("created_at", "-")
        idx_head = idx.get("repo_head", "")
        current_head = short_git_head()
        if idx_head and current_head and idx_head != current_head:
            context_status = "Índice desatualizado"
        else:
            context_status = "Índice pronto"
        source_label = "cache"
    else:
        indexable_docs = docs_count + (1 if (target_root / "README.md").is_file() else 0)
        indexable_runs = len(runs)
        indexable_patches = sum(len(list(d.glob("*.json"))) for _, d in iter_artifact_dirs("patches", workspace_id) if d.exists())
        last_index_update = "-"
        context_status = "Sem índice, usando varredura direta"
        source_label = "direct"

    return {
        "README": (target_root / "README.md").is_file(),
        "workspace_id": workspace_id,
        "artifact_scope": "scoped",
        "context_dir": str(workspace_context_dir(target_root, workspace_id)),
        "workspace_root": str(target_root),
        "docs": docs_dir.is_dir(),
        "docs_count": docs_count,
        "runbooks": runbooks_dir.is_dir(),
        "runbooks_count": len(runbook_files),
        "recent_runbooks": [str(p.relative_to(ROOT)) for p in runbook_files[:5]],
        "architecture_count": len(arch_files),
        "roadmap_count": len(roadmap_files),
        "model_strategy": (target_root / "docs" / "MODEL_STRATEGY.md").is_file(),
        "model_bench": model_bench_dir.is_dir(),
        "litellm_config": (target_root / "config" / "litellm.yaml").is_file(),
        "aiw_runtime": (target_root / "aiw_runtime").is_dir(),
        "scripts_ok": all((ROOT / s).is_file() for s in script_checks),
        "scripts_checked": script_checks,
        "pending_patches": len([p for p in list_patch_proposals(100) if p["status"] == "preview"]),
        "recent_runs": len(runs),
        "last_offline": last_offline,
        "last_online": last_online,
        "git_head": short_git_head(),
        "branch": current_git_branch(),
        "context_status": context_status,
        "source_label": source_label,
        "score": f"{score}/{len(checks_ok)}",
        "indexable_docs": indexable_docs,
        "indexable_runs": indexable_runs,
        "indexable_patches": indexable_patches,
        "last_index_update": last_index_update,
    }


def list_inbox_tasks(limit: int = 20) -> list[dict]:
    inbox = ROOT / ".aiw" / "tasks" / "inbox"
    if not inbox.exists():
        return []
    tasks = []
    for md in sorted(inbox.glob("*.md"), reverse=True)[:limit]:
        lines = md.read_text(encoding="utf-8", errors="replace").splitlines()
        title = "-"
        task_type = "task"
        doc_output = ""
        created_at = ""
        for line in lines:
            if line.startswith("# "):
                title = line[2:].strip()
            elif line.startswith("Type:"):
                task_type = line.split(":", 1)[1].strip()
            elif line.startswith("Output:") or line.startswith("Doc:"):
                doc_output = line.split(":", 1)[1].strip()
            elif line.startswith("Created:"):
                created_at = line.split(":", 1)[1].strip()
        tasks.append({
            "file": md.name,
            "title": title,
            "type": task_type,
            "doc_output": doc_output,
            "created_at": created_at,
        })
    return tasks


def status_payload() -> dict:
    workspace_id = active_workspace_id()
    return {
        "root": str(ROOT),
        "workspace_id": workspace_id,
        "queues": {q: count_tasks(q) for q in TASK_QUEUES},
        "runs": list_runs(25, workspace_id),
    }


def model_select_html(name: str = "model", selected: str = "dev-gemini-fast") -> str:
    opts = ""
    for label, value in MODEL_OPTIONS:
        sel = ' selected' if value == selected else ''
        opts += f'<option value="{html.escape(value)}"{sel}>{html.escape(label)}</option>\n'
    return f'<select class="input model-select" name="{name}">\n{opts}</select>'


