#!/usr/bin/env bash
# Wrapper to execute the original AIW Cockpit Python code.
# This allows bash -n syntax checking while delegating to Python.
exec python3 - <<'PYTHON'
import html
import json
import os
import socketserver
import subprocess
import webbrowser
from http.server import BaseHTTPRequestHandler
from pathlib import Path
from urllib.parse import parse_qs, quote, urlparse


ROOT = Path(os.environ.get("AIW_ROOT", Path.home() / "ai-workbench")).resolve()
# Fallback to repository path if default does not exist
if not ROOT.is_dir():
    ROOT = Path("/home/joao/ai-workbench").resolve()
PORT = int(os.environ.get("AIW_COCKPIT_PORT", "8765"))
HOST = os.environ.get("AIW_COCKPIT_HOST", "127.0.0.1")
OPEN_BROWSER = os.environ.get("AIW_COCKPIT_OPEN_BROWSER", "0") == "1"

TASK_QUEUES = ["inbox", "running", "blocked", "queued", "done", "failed"]

MODEL_OPTIONS = [
    ("Rápido", "dev-gemini-fast"),
    ("Código", "dev-coder"),
    ("Balanceado", "dev-balanced"),
    ("Grande", "dev-large"),
    ("Revisão", "dev-review"),
    ("Arquitetura", "dev-architect"),
]


def count_tasks(queue: str) -> int:
    path = ROOT / ".aiw" / "tasks" / queue
    if not path.exists():
        return 0
    return len([p for p in path.glob("*.md") if p.is_file()])


def read_json(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {"status": "invalid_json"}


def read_task_id(run_dir: Path) -> str:
    task = run_dir / "task.md"
    if not task.exists():
        return "-"
    for line in task.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.startswith("Task ID:"):
            return line.split(":", 1)[1].strip() or "-"
    return "-"


def read_task_title(run_dir: Path) -> str:
    task = run_dir / "task.md"
    if not task.exists():
        return "-"
    for line in task.read_text(encoding="utf-8", errors="replace").splitlines():
        if line.startswith("# "):
            return line[2:].strip() or "-"
    return "-"


def read_summary_first_lines(run_dir: Path, lines: int = 3) -> str:
    summary = run_dir / "summary.md"
    if not summary.exists():
        return ""
    text = summary.read_text(encoding="utf-8", errors="replace")
    parts = [l for l in text.splitlines() if l.strip()]
    return " ".join(parts[:lines])


def list_runs(limit: int = 25) -> list[dict]:
    runs_dir = ROOT / ".aiw" / "runs"
    if not runs_dir.exists():
        return []

    rows = []
    for run in sorted([p for p in runs_dir.iterdir() if p.is_dir()], reverse=True)[:limit]:
        status = read_json(run / "status.json")
        rows.append({
            "run": str(run.relative_to(ROOT)),
            "task_id": read_task_id(run),
            "title": read_task_title(run),
            "status": status.get("status", "unknown"),
            "llm_status": status.get("llm_status", "-"),
            "doc_status": status.get("doc_status", "-"),
            "generated_file": status.get("generated_file", ""),
            "model": status.get("model", "-"),
            "summary": read_summary_first_lines(run),
        })
    return rows


def list_inbox_tasks(limit: int = 20) -> list[dict]:
    inbox = ROOT / ".aiw" / "tasks" / "inbox"
    if not inbox.exists():
        return []
    tasks = []
    for md in sorted(inbox.glob("*.md"), reverse=True)[:limit]:
        lines = md.read_text(encoding="utf-8", errors="replace").splitlines()
        title = "-"
        task_type = "task"
        doc_output = ""
        created_at = ""
        for line in lines:
            if line.startswith("# "):
                title = line[2:].strip()
            elif line.startswith("Type:"):
                task_type = line.split(":", 1)[1].strip()
            elif line.startswith("Output:") or line.startswith("Doc:"):
                doc_output = line.split(":", 1)[1].strip()
            elif line.startswith("Created:"):
                created_at = line.split(":", 1)[1].strip()
        tasks.append({
            "file": md.name,
            "title": title,
            "type": task_type,
            "doc_output": doc_output,
            "created_at": created_at,
        })
    return tasks


def status_payload() -> dict:
    return {
        "root": str(ROOT),
        "queues": {q: count_tasks(q) for q in TASK_QUEUES},
        "runs": list_runs(25),
    }


def model_select_html(name: str = "model", selected: str = "dev-gemini-fast") -> str:
    opts = ""
    for label, value in MODEL_OPTIONS:
        sel = ' selected' if value == selected else ''
        opts += f'<option value="{html.escape(value)}"{sel}>{html.escape(label)}</option>\n'
    return f'<select class="input model-select" name="{name}">\n{opts}</select>'


