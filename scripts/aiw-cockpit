    }}
  </style>
</head>
<body>
  <main>
    <header>
      <div>
        <h1>AIW Local Cockpit</h1>
        <div class="subtitle">Painel local do AI Workbench MVP. Root: <code>{html.escape(str(ROOT))}</code></div>
