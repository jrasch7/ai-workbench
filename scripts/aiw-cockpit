def render_page() -> str:
    payload = status_payload()
    queues = payload["queues"]
    runs = payload["runs"]
    inbox_tasks = list_inbox_tasks()

    # Queue pills
    queue_pills = ""
    for name, count in queues.items():
        queue_pills += f'<div class="queue-pill"><span class="q-name">{html.escape(name)}</span><span class="q-count">{count}</span></div>\n'

    # Inbox badge
    inbox_count = queues.get("inbox", 0)
    review_count = queues.get("review", 0)
    running_count = queues.get("running", 0)
    done_count = queues.get("done", 0)
    failed_count = queues.get("failed", 0)

    def badge(n, cls=""):
        if n == 0:
            return ""
        return f'<span class="badge {cls}">{n}</span>'

    # Sidebar nav items
    nav_html = f"""
    <div class="sidebar-logo">
      <h1>AIW Cockpit</h1>
      <div class="version">Agent Workspace v2</div>
    </div>
    <nav class="nav-section">
      <div class="nav-label">Workspace</div>
      <button class="nav-item active" onclick="showSection('overview')"><span class="icon">◎</span>Overview</button>
      <button class="nav-item" onclick="showSection('nova')"><span class="icon">✦</span>Nova task</button>
    </nav>
    <nav class="nav-section">
      <div class="nav-label">Tarefas</div>
      <button class="nav-item" onclick="showSection('inbox')"><span class="icon">⬚</span>Inbox {badge(inbox_count)}</button>
      <button class="nav-item" onclick="showSection('running')"><span class="icon">▷</span>Running {badge(running_count, 'ok')}</button>
    </nav>
    <nav class="nav-section">
      <div class="nav-label">Revisão</div>
      <button class="nav-item" onclick="showSection('review')"><span class="icon">◈</span>Review {badge(review_count, 'warn')}</button>
      <button class="nav-item" onclick="showSection('done')"><span class="icon">✓</span>Done {badge(done_count, 'ok')}</button>
      <button class="nav-item" onclick="showSection('failed')"><span class="icon">✗</span>Failed {badge(failed_count, 'danger')}</button>
    </nav>
    <nav class="nav-section">
      <div class="nav-label">Sistema</div>
      <a class="nav-item" href="/api/status"><span class="icon">⌥</span>Models</a>
      <a class="nav-item" href="/api/status"><span class="icon">≡</span>Docs</a>
      <a class="nav-item" href="/api/status"><span class="icon">◉</span>Settings</a>
    </nav>
    <div class="sidebar-footer">
      <span class="status-dot">●</span>Local · auto-refresh 10s
    </div>
    """

    # Composer
    model_sel = model_select_html()
    composer_html = f"""
    <div class="composer">
      <h3>O que você quer que o AIW faça?</h3>
      <div class="composer-sub">Descreva o objetivo em linguagem humana. O AIW executa com IA por padrão.</div>
      <form method="post" action="/task/create" id="composer-form">
        <textarea name="title" placeholder="Ex: Melhorar o README do projeto, documentar o fluxo de onboarding e criar exemplos de uso para novos contribuidores..." required></textarea>
        <div class="composer-row">
          <div>
            <label>Modelo</label>
            {model_sel}
          </div>
          <div style="flex:1;min-width:240px">
            <label>Arquivo de documentação (opcional)</label>
            <input class="input doc-input" name="output" placeholder="Ex: docs/AIW_CURRENT_STATE_AND_GAP_ANALYSIS.md" style="width:100%">
          </div>
        </div>
        <div class="form-help" style="color:var(--muted);font-size:12px;margin-bottom:14px">
          Deixe o campo de doc vazio para uma task comum. Preencha <code>docs/*.md</code> para obrigar o AIW a criar ou atualizar documentação.
        </div>
        <div class="composer-actions">
          <button class="btn btn-primary" type="submit" name="_action" value="run">Criar e executar com IA</button>
          <button class="btn btn-secondary" type="submit" name="_action" value="save">Salvar na inbox</button>
        </div>
      </form>
    </div>
    """

    # Execution context panel (shown before running)
    next_task = inbox_tasks[0] if inbox_tasks else None
    if next_task:
        next_title = html.escape(next_task["title"])
        next_type = html.escape(next_task["type"])
        next_doc = html.escape(next_task.get("doc_output", ""))
        doc_line = f'<div class="card-doc">→ {next_doc}</div>' if next_doc else ""
        exec_panel = f"""
        <div class="section-block">
          <h3>Executar próxima task</h3>
          <div class="card" style="max-width:560px">
            <div class="card-title">{next_title}</div>
            <div class="card-meta">
              <span class="tag status-inbox">{next_type}</span>
              <span class="tag">inbox</span>
            </div>
            {doc_line}
            <form method="post" action="/runner/run-once" style="display:flex;flex-direction:column;gap:10px">
              <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
                <div>
                  <label style="color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:4px">Modelo</label>
                  {model_select_html(name='model')}
                </div>
              </div>
              <div style="display:flex;gap:8px;flex-wrap:wrap">
                <button class="btn btn-run" type="submit">Executar task selecionada</button>
              </div>
            </form>
          </div>
        </div>
        """
    else:
        exec_panel = """
        <div class="section-block">
          <h3>Executar próxima task</h3>
          <div class="empty-state">Inbox vazia. Crie uma task acima para começar.</div>
        </div>
        """

    # Inbox cards
    if inbox_tasks:
        inbox_cards = ""
        for t in inbox_tasks:
            doc_line = f'<div class="card-doc">→ {html.escape(t["doc_output"])}</div>' if t.get("doc_output") else ""
            created = f'<div class="card-date">{html.escape(t.get("created_at",""))}</div>' if t.get("created_at") else ""
            inbox_cards += f"""
            <div class="card">
              <div class="card-title">{html.escape(t["title"])}</div>
              <div class="card-meta">
                <span class="tag">{html.escape(t["type"])}</span>
                <span class="tag status-inbox">inbox</span>
              </div>
              {doc_line}
              {created}
              <div class="card-actions">
                <form method="post" action="/runner/run-once" style="display:inline">
                  <button class="btn btn-run" type="submit">Executar</button>
                </form>
              </div>
            </div>
            """
    else:
        inbox_cards = '<div class="empty-state">Nenhuma task na inbox.</div>'

    # Review / Activity sections
    queued_runs = [r for r in runs if r["status"] == "queued"]
    queued_runs = [r for r in runs if r["status"] == "queued"]

    def run_card(row: dict) -> str:
        st = html.escape(row["status"])
        model = html.escape(row["model"])
        title = html.escape(row["title"])
        summary = html.escape(row["summary"])
        run_path = html.escape(row["run"])
        doc = html.escape(row.get("generated_file", ""))
        doc_line = f'<div class="card-doc">→ {doc}</div>' if doc else ""
        summary_line = f'<div class="card-summary">{summary}</div>' if summary else ""
        return f"""
        <div class="card">
          <div class="card-title">{title if title != "-" else html.escape(row["task_id"])}</div>
          <div class="card-meta">
            <span class="tag status-{st}">{st}</span>
            <span class="tag">{model}</span>
          </div>
          {doc_line}
          {summary_line}
          <div class="card-actions">
            <a class="btn btn-secondary" href="/run?path={quote(row['run'])}">Revisar</a>
          </div>
        </div>
        """

    if queued_runs:
        atencao_cards = "".join(run_card(r) for r in queued_runs)
        atencao_section = f"""
        <div class="section-block">
          <h3>Precisa da sua atenção</h3>
          <div class="cards">{atencao_cards}</div>
        </div>
        """
    else:
        atencao_section = f"""
        <div class="section-block">
          <h3>Precisa da sua atenção</h3>
          <div class="empty-state">Nenhum run aguardando revisão.</div>
        </div>
        """

    if other_runs:
        recent_cards = "".join(run_card(r) for r in other_runs[:8])
        recent_section = f"""
        <div class="section-block">
          <h3>Atividade recente</h3>
          <div class="cards">{recent_cards}</div>
        </div>
        """
    else:
        recent_section = f"""
        <div class="section-block">
          <h3>Atividade recente</h3>
          <div class="empty-state">Nenhum run encontrado.</div>
        </div>
        """

    # Overview section content
    overview_section = f"""
    <div id="sec-overview" class="workspace-section">
      <div class="page-header">
        <h2>Overview</h2>
        <div class="sub">Visão geral do workspace. Root: <code>{html.escape(str(ROOT))}</code></div>
      </div>
      <div class="queue-bar">{queue_pills}</div>
      {atencao_section}
      {recent_section}
      <div class="api-links">
        <a class="api-link" href="/api/status">/api/status</a>
        <a class="api-link" href="/api/runs">/api/runs</a>
      </div>
    </div>
    """

    nova_section = f"""
    <div id="sec-nova" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Nova task</h2>
        <div class="sub">Crie uma task e execute imediatamente com IA, ou salve na inbox.</div>
      </div>
      {composer_html}
      {exec_panel}
    </div>
    """

    inbox_section = f"""
    <div id="sec-inbox" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Inbox</h2>
        <div class="sub">Tasks aguardando execução.</div>
      </div>
      <div class="cards">{inbox_cards}</div>
    </div>
    """

    running_section = f"""
    <div id="sec-running" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Running</h2>
        <div class="sub">Tasks em execução agora.</div>
      </div>
      {"".join(run_card(r) for r in runs if r['status'] == 'running') or '<div class="empty-state">Nenhuma task em execução.</div>'}
    </div>
    """

    review_section = f"""
    <div id="sec-review" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Review</h2>
        <div class="sub">Runs que precisam da sua revisão e decisão.</div>
      </div>
      <div class="cards">{"".join(run_card(r) for r in review_runs) or '<div class="empty-state">Nenhum run para revisar.</div>'}</div>
    </div>
    """

    done_section = f"""
    <div id="sec-done" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Done</h2>
        <div class="sub">Tasks aprovadas e concluídas.</div>
      </div>
      <div class="cards">{"".join(run_card(r) for r in runs if r['status'] == 'done') or '<div class="empty-state">Nenhuma task concluída ainda.</div>'}</div>
    </div>
    """

    failed_section = f"""
    <div id="sec-failed" class="workspace-section" style="display:none">
      <div class="page-header">
        <h2>Failed</h2>
        <div class="sub">Runs rejeitados ou com falha.</div>
      </div>
      <div class="cards">{"".join(run_card(r) for r in runs if r['status'] in ('failed','rejected')) or '<div class="empty-state">Nenhuma falha registrada.</div>'}</div>
    </div>
    """

    return f"""<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>AIW Cockpit</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="10">
  <style>{_CSS}</style>
</head>
<body>
  <div class="workspace">
    <aside class="sidebar">
      {nav_html}
    </aside>
    <main class="main">
      {overview_section}
      {nova_section}
      {inbox_section}
      {running_section}
      {review_section}
      {done_section}
      {failed_section}
    </main>
  </div>
  <script>
    function showSection(name) {{
      document.querySelectorAll('.workspace-section').forEach(el => el.style.display = 'none');
      var sec = document.getElementById('sec-' + name);
      if (sec) sec.style.display = '';
      document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
      var clicked = event && event.currentTarget;
      if (clicked) clicked.classList.add('active');
    }}
  </script>
</body>
</html>"""


def safe_run_dir(raw_path: str) -> Path | None:
    if not raw_path:
        return None

    if raw_path.startswith("/") or ".." in raw_path:
        return None

    if not raw_path.startswith(".aiw/runs/"):
        return None

    run_dir = (ROOT / raw_path).resolve()
    runs_root = (ROOT / ".aiw" / "runs").resolve()

    try:
        run_dir.relative_to(runs_root)
    except ValueError:
        return None

    if not run_dir.exists() or not run_dir.is_dir():
        return None

    return run_dir


def read_text_file(path: Path, limit: int = 20000) -> str:
    if not path.exists() or not path.is_file():
        return ""

    text = path.read_text(encoding="utf-8", errors="replace")

    if len(text) > limit:
        return text[:limit] + "\n\n--- TRUNCATED ---\n"

    return text


def create_task_from_cockpit(title: str, output: str = "") -> tuple[bool, str]:
    title = (title or "").strip()
    output = (output or "").strip()

    if not title:
        return False, "task title is required"

    if output:
        if not output.startswith("docs/") or not output.endswith(".md") or ".." in output or output.startswith("/") or ".env" in output:
            return False, "invalid output path"
        cmd = [str(ROOT / "scripts" / "aiw-doc-task-create"), title, output]
    else:
        cmd = [str(ROOT / "scripts" / "aiw-task-create"), title]

    try:
        completed = subprocess.run(
            cmd,
            cwd=str(ROOT),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=30,
            check=False,
        )
    except Exception as exc:
        return False, f"task creation failed: {exc}"

    ok = completed.returncode == 0
    return ok, completed.stdout.strip()


def run_once_from_cockpit(llm_enabled: str = "1", model: str = "dev-gemini-fast") -> tuple[bool, str, str]:
    enabled = "1" if llm_enabled != "0" else "0"
    model = (model or "dev-gemini-fast").strip()

    allowed = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.:/")
    if not model or any(ch not in allowed for ch in model):
        return False, "invalid model", ""

    env = os.environ.copy()
    env["AIW_LLM_ENABLED"] = enabled
    env["AIW_MODEL"] = model

    try:
        completed = subprocess.run(
            [str(ROOT / "scripts" / "aiw-runner-once")],
            cwd=str(ROOT),
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=300,
            check=False,
        )
    except Exception as exc:
        return False, f"runner failed: {exc}", ""

    output = completed.stdout.strip()
    run_dir = ""

    for line in output.splitlines():
        if line.startswith("RUN_DIR:"):
            run_dir = line.split(":", 1)[1].strip()

    ok = completed.returncode == 0 and bool(run_dir)
    return ok, output, run_dir


def run_action(action: str, run_path: str, reason: str = "") -> tuple[bool, str]:
    run_dir = safe_run_dir(run_path)

    if run_dir is None:
        return False, "invalid run path"

    rel = str(run_dir.relative_to(ROOT))

    if action == "approve":
        cmd = [str(ROOT / "scripts" / "aiw-run-approve"), rel]
    elif action == "reject":
        cmd = [str(ROOT / "scripts" / "aiw-run-reject"), rel, reason or "Rejected from AIW Local Cockpit."]
    else:
        return False, "invalid action"

    try:
        completed = subprocess.run(
            cmd,
            cwd=str(ROOT),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=30,
            check=False,
        )
    except Exception as exc:
        return False, f"action failed: {exc}"

    ok = completed.returncode == 0
    return ok, completed.stdout.strip()


def render_file_block(title: str, content: str) -> str:
    if not content:
        return f"""
        <div class="file-block muted">
          <div class="file-head"><h4>{html.escape(title)}</h4></div>
          <pre class="pre-empty">Arquivo ausente ou vazio.</pre>
        </div>
        """

    return f"""
    <div class="file-block">
      <div class="file-head"><h4>{html.escape(title)}</h4></div>
      <pre>{html.escape(content)}</pre>
    </div>
    """


def render_run_detail(run_dir: Path) -> str:
    rel = str(run_dir.relative_to(ROOT))
    status = read_json(run_dir / "status.json")

    status_label = status.get("status", "unknown")
    doc_status = status.get("doc_status", "-")
    llm_status = status.get("llm_status", "-")
    model = status.get("model", "-")
    generated_file = status.get("generated_file", "")

    # Objective from task.md
    task_text = read_text_file(run_dir / "task.md")
    objective = ""
    if task_text:
        for line in task_text.splitlines():
            if line.startswith("# "):
                objective = line[2:].strip()
                break
        if not objective:
            objective = task_text[:200].strip()

    # Result from summary.md
    result_text = read_text_file(run_dir / "summary.md", limit=4000)

    # Priority blocks
    objective_block = f"""
    <div class="priority-block">
      <h3>Objetivo</h3>
      <div class="objective-text">{html.escape(objective) if objective else '<span style="color:var(--muted)">Não encontrado</span>'}</div>
    </div>
    """ if objective else ""

    result_block = f"""
    <div class="priority-block">
      <h3>Resultado</h3>
      <div class="result-text"><pre style="background:none;padding:0;font-size:13px">{html.escape(result_text)}</pre></div>
    </div>
    """ if result_text else ""

    file_block = ""
    if generated_file:
        file_block = f"""
        <div class="priority-block">
          <h3>Arquivo gerado</h3>
          <div class="card-doc" style="font-size:14px">→ {html.escape(generated_file)}</div>
        </div>
        """

    # Action bar
    next_action = ""
    if status_label == "review":
        next_action = "<strong>Ação recomendada:</strong> Revisar o resultado e aprovar ou rejeitar."
    elif status_label == "done":
        next_action = "<strong>Status:</strong> Aprovado. Nenhuma ação necessária."
    elif status_label == "failed":
        next_action = "<strong>Status:</strong> Falhou ou foi rejeitado."
    else:
        next_action = f"<strong>Status:</strong> {html.escape(status_label)}"

    action_bar = f"""
    <div class="action-bar">
      <form method="post" action="/action/approve">
        <input type="hidden" name="path" value="{html.escape(rel)}">
        <button class="btn btn-run" type="submit">Aprovar</button>
      </form>
      <form method="post" action="/action/reject" class="reject-inline">
        <input type="hidden" name="path" value="{html.escape(rel)}">
        <input class="input" name="reason" placeholder="Motivo da rejeição..." aria-label="Motivo">
        <button class="btn btn-danger" type="submit">Rejeitar com motivo</button>
      </form>
      <!-- Cancel button for running/queued runs -->
      <form method="post" action="/api/runs/{html.escape(rel)}/cancel" class="reject-inline">
        <button class="btn btn-danger" type="submit">Cancelar run</button>
      </form>

      <a class="btn btn-ghost" href="/">Voltar para review</a>
      <div style="margin-left:auto;color:var(--muted);font-size:12px;align-self:center">{next_action}</div>
    </div>
    """

    # Secondary files (priority order from spec)
    secondary_files = [
        "summary.md",
        "validation.log",
        "llm-output.md",
        "commands.log",
        "status.json",
        "task.md",
    ]
    file_blocks = ""
    for fname in secondary_files:
        file_blocks += render_file_block(fname, read_text_file(run_dir / fname))

    # Also show approval/rejection/error if present
    for fname in ["approval.md", "rejection.md", "llm-error.log"]:
        content = read_text_file(run_dir / fname)
        if content:
            file_blocks += render_file_block(fname, content)

    return f"""<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>AIW Run Detail</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>{_CSS}</style>
</head>
<body>
  <div class="workspace">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <h1>AIW Cockpit</h1>
        <div class="version">Agent Workspace v2</div>
      </div>
      <nav class="nav-section">
        <a class="nav-item" href="/"><span class="icon">←</span>Voltar ao workspace</a>
      </nav>
      <div class="sidebar-footer">
        <span class="status-dot">●</span>Local only
      </div>
    </aside>
    <main class="main">
      <div class="detail-header">
        <a class="back" href="/">← Voltar ao workspace</a>
        <h2>Detalhe do run</h2>
        <div class="run-path">{html.escape(rel)}</div>
      </div>
      <div class="detail-meta-bar">
        <div class="meta-chip">
          <div class="chip-label">Status</div>
          <div class="chip-value"><span class="tag status-{html.escape(str(status_label))}">{html.escape(str(status_label))}</span></div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">Modelo</div>
          <div class="chip-value">{html.escape(str(model))}</div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">Doc</div>
          <div class="chip-value">{html.escape(str(doc_status))}</div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">LLM</div>
          <div class="chip-value">{html.escape(str(llm_status))}</div>
        </div>
      </div>

      {objective_block}
      {result_block}
      {file_block}
      {action_bar}

      <div class="detail-files">
        {file_blocks}
      </div>
    </main>
  </div>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print("%s - %s" % (self.address_string(), fmt % args))

    def send_json(self, payload: dict, status: int = 200):
        body = json.dumps(payload, ensure_ascii=False, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, body: str, status: int = 200):
        raw = body.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(raw)))
        self.end_headers()
        self.wfile.write(raw)

    def do_GET(self):
        # Existing GET handling remains unchanged – omitted for brevity
        # New endpoints for analysis artifacts
        if path.startswith("/api/runs/") and path.endswith("/diff-summary") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            diff_file = run_dir / "diff-summary.md"
            if diff_file.is_file():
                self.send_markdown(diff_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        if path.startswith("/api/runs/") and path.endswith("/handoff") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            handoff_file = run_dir / "handoff.md"
            if handoff_file.is_file():
                self.send_markdown(handoff_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        if path.startswith("/api/runs/") and path.endswith("/validator") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            validator_file = run_dir / "validator.md"
            if validator_file.is_file():
                self.send_markdown(validator_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        # fall through to existing logic

        path = urlparse(self.path).path

        if path == "/":
            self.send_html(render_page())
            return

        if path == "/run":
            query = parse_qs(urlparse(self.path).query)
            raw_path = query.get("path", [""])[0]
            run_dir = safe_run_dir(raw_path)

            if run_dir is None:
                self.send_json({"error": "invalid_or_missing_run", "path": raw_path}, status=404)
                return

            self.send_html(render_run_detail(run_dir))
            return

        if path == "/api/status":
            self.send_json(status_payload())
            return

        if path == "/api/runs":
                self.send_json({"runs": list_runs(50)})
                return
        # Cancel endpoint: POST /api/runs/<run_path>/cancel
        if path.startswith("/api/runs/") and path.endswith("/cancel") and self.command == "POST":
            # Extract run_path between /api/runs/ and /cancel
            parts = path.split('/')
            if len(parts) >= 5:
                run_path = '/'.join(parts[3:-1])
            else:
                self.send_json({"error": "invalid_path"}, status=400)
                return
            run_dir = safe_run_dir(run_path)
            if run_dir is None:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            status_path = run_dir / "status.json"
            if not status_path.is_file():
                self.send_json({"error": "status_not_found"}, status=404)
                return
            import json, datetime
            data = json.loads(status_path.read_text())
            if data.get("status") in ("succeeded", "failed", "cancelled", "timed_out"):
                # already finished
                self.send_json({"run_id": run_path, "status": data.get("status")})
                return
            # set cancel flag and status
            data["cancel_requested"] = True
            data["status"] = "cancelled"
            now = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
            data["finished_at"] = now
            # attempt to kill pid if present
            pid = data.get("pid")
            if pid:
                try:
                    os.kill(pid, 9)
                except Exception:
                    pass
            status_path.write_text(json.dumps(data, indent=2))
            self.send_json({"run_id": run_path, "status": "cancelled"})
            return
        # Analysis endpoint: POST /api/runs/<run_path>/analyze
        if path.startswith("/api/runs/") and path.endswith("/analyze") and self.command == "POST":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            status_path = run_dir / "status.json"
            if not status_path.is_file():
                self.send_json({"error": "status_not_found"}, status=404)
                return
            import json, datetime, subprocess, shlex, textwrap
            data = json.loads(status_path.read_text())
            if data.get("status") in ("queued", "running"):
                self.send_json({"error": "run_not_finished"}, status=409)
                return
            # ---- Diff Summary ----
            diff_summary_path = run_dir / "diff-summary.md"
            now = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
            sections = []
            sections.append("# Diff Summary\n")
            sections.append("## Run\n")
            sections.append(f"* Run ID: {data.get('id','')}")
            sections.append(f"* Title: {data.get('title','')}")
            sections.append(f"* Status: {data.get('status','')}")
            sections.append(f"* Created at: {data.get('created_at','')}")
            sections.append(f"* Finished at: {data.get('finished_at','')}")
            sections.append("\n## Git Status\n")
            gs = subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{gs}\n```")
            sections.append("\n## Diff Stat\n")
            ds = subprocess.run(["git", "diff", "--stat"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{ds}\n```")
            sections.append("\n## Diff Check\n")
            dc = subprocess.run(["git", "diff", "--check"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{dc if dc else 'No issues'}\n```")
            sections.append("\n## Changed Files\n")
            cf = subprocess.run(["git", "diff", "--name-only"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{cf if cf else 'No files changed'}\n```")
            sections.append("\n## Recent Commits\n")
            rc = subprocess.run(["git", "log", "--oneline", "-5"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{rc}\n```")
            diff_summary_path.write_text("\n".join(sections))
            # ---- Handoff ----
            handoff_path = run_dir / "handoff.md"
            mission_path = run_dir / "task.md"
            mission_content = mission_path.read_text() if mission_path.is_file() else ""
            handoff_md = textwrap.dedent(f"""
            # AIW Run Handoff

            ## Summary

            * Run ID: {data.get('id','')}
            * Title: {data.get('title','')}
            * Final status: {data.get('status','')}
            * Exit code: {data.get('exit_code','')}
            * Started: {data.get('started_at','')}
            * Finished: {data.get('finished_at','')}
            * Duration: {data.get('duration','')}

            ## Mission
            ```text
            {mission_content}
            ```

            ## Evidence
            * Metadata: {status_path.name}
            * Log: {run_dir / 'commands.log'}
            * Diff summary: {diff_summary_path.name}
            * Validation: {run_dir / 'validation.json'}

            ## Risks
            * Diff check issues: {'Yes' if dc else 'No'}
            * Working tree dirty after run: {'Yes' if subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip() else 'No'}
            """)
            handoff_path.write_text(handoff_md)
            # ---- Validator ----
            validator_path = run_dir / "validator.md"
            validation_json_path = run_dir / "validation.json"
            checks = []
            # metadata exists
            checks.append({"name": "metadata_exists", "status": "passed" if status_path.is_file() else "failed", "details": ""})
            # log exists
            log_path = run_dir / "commands.log"
            checks.append({"name": "log_exists", "status": "passed" if log_path.is_file() else "failed", "details": ""})
            # status final allowed
            allowed = {"queued","running","succeeded","failed","cancelled","timed_out"}
            final_status = data.get('status','')
            checks.append({"name": "final_status_allowed", "status": "passed" if final_status in allowed else "failed", "details": f"{final_status}"})
            # exit code check
            exit_code = data.get('exit_code')
            if final_status == 'succeeded':
                checks.append({"name": "exit_code_zero", "status": "passed" if exit_code == 0 else "failed", "details": f"{exit_code}"})
            # diff check
            diff_check_err = bool(dc)
            checks.append({"name": "git_diff_check", "status": "passed" if not diff_check_err else "failed", "details": dc if diff_check_err else ""})
            # reports not staged
            st = subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            reports_dirty = any(line.startswith('?? reports/') or line.startswith('A  reports/') for line in st.splitlines())
            checks.append({"name": "reports_not_staged", "status": "passed" if not reports_dirty else "failed", "details": ""})
            # secrets check (very simple) – look for .env patterns in changed files
            secret_leak = False
            for f in cf.splitlines():
                if f.endswith('.env'):
                    secret_leak = True
                    break
            checks.append({"name": "secrets_not_leaked", "status": "passed" if not secret_leak else "failed", "details": ""})
            # aggregate
            overall = "passed" if all(c['status']=='passed' for c in checks) else "failed"
            validation_json = {
                "run_id": data.get('id',''),
                "status": overall,
                "checks": checks,
                "recommended_action": "none" if overall=='passed' else "review"
            }
            validation_json_path.write_text(json.dumps(validation_json, indent=2))
            # validator.md human readable
            validator_md = "# Validator Report\n\n" + "\n".join([f"* {c['name']}: {c['status']}" for c in checks])
            validator_path.write_text(validator_md)
            # update metadata with artifact paths and validation status
            data.update({
                "diff_summary_path": str(diff_summary_path),
                "handoff_path": str(handoff_path),
                "validator_path": str(validator_path),
                "validation_path": str(validation_json_path),
                "validation_status": overall,
                "recommended_action": validation_json["recommended_action"]
            })
            status_path.write_text(json.dumps(data, indent=2))
            # respond
            self.send_json({"run_id": run_path, "analysis": "completed", "validation_status": overall})
            return
        # fall through to existing logic

    def do_POST(self):
        path = urlparse(self.path).path

        length = int(self.headers.get("Content-Length", "0") or "0")
        raw = self.rfile.read(length).decode("utf-8", errors="replace")

        content_type = self.headers.get("Content-Type", "")

        # JSON API endpoint for task creation
        if path == "/api/task/create":
            try:
                data = json.loads(raw) if raw else {}
            except Exception:
                self.send_json({"error": "invalid_json"}, status=400)
                return
            title = data.get("title", "")
            doc_output = data.get("output", data.get("doc_output", ""))
            model = data.get("model", "dev-gemini-fast")
            ok, output = create_task_from_cockpit(title, doc_output)
            if ok:
                self.send_json({"ok": True, "output": output, "model": model})
            else:
                self.send_json({"ok": False, "error": output}, status=400)
            return

        # Form-encoded endpoints
        form = parse_qs(raw)

        run_path = form.get("path", [""])[0]
        reason = form.get("reason", [""])[0]

        if path == "/task/create":
            title = form.get("title", [""])[0]
            doc_output = form.get("output", [""])[0]
            ok, output = create_task_from_cockpit(title, doc_output)
            redirect = "/"
        elif path == "/runner/run-once":
            # AI is on by default — llm_enabled defaults to "1"
            llm_enabled = form.get("llm_enabled", ["1"])[0]
            model = form.get("model", ["dev-gemini-fast"])[0]
            ok, output, generated_run = run_once_from_cockpit(llm_enabled, model)
            redirect = f"/run?path={quote(generated_run)}" if generated_run else "/"
        elif path == "/action/approve":
            ok, output = run_action("approve", run_path)
            redirect = f"/run?path={quote(run_path)}"
        elif path == "/action/reject":
            ok, output = run_action("reject", run_path, reason)
            redirect = f"/run?path={quote(run_path)}"
        else:
            self.send_json({"error": "not_found", "path": path}, status=404)
            return

        if not ok:
            self.send_json({"error": "action_failed", "output": output}, status=400)
            return

        self.send_response(303)
        self.send_header("Location", redirect)
        self.end_headers()


class ThreadingTCPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
    allow_reuse_address = True


if __name__ == "__main__":
    if not ROOT.exists():
        raise SystemExit(f"AIW root not found: {ROOT}")

    url = f"http://{HOST}:{PORT}"
    print(f"AIW Local Cockpit running at {url}")
    print(f"ROOT: {ROOT}")
    print("Press Ctrl+C to stop")

    if OPEN_BROWSER:
        webbrowser.open(url)

    with ThreadingTCPServer((HOST, PORT), Handler) as httpd:
        httpd.serve_forever()
