    function activateButton(button, selector) {{
      document.querySelectorAll(selector).forEach(el => el.classList.remove('active'));
      button.classList.add('active');
    }}
    function filterRuns(value, button) {{
      activateButton(button, '[data-run-filter-btn]');
      try {{ localStorage.setItem('aiw_run_filter', value); }} catch(e) {{}}
      var shown = 0;
      document.querySelectorAll('[data-run-filter]').forEach(card => {{
        var flags = (card.getAttribute('data-run-filter') || '').split(' ');
        var match = value === 'all' || flags.indexOf(value) >= 0;
        card.style.display = match ? '' : 'none';
        if (match) shown += 1;
      }});
      var empty = document.getElementById('run-filter-empty');
      if (empty) empty.style.display = shown ? 'none' : '';
    }}
    function filterPatches(value, button) {{
      activateButton(button, '[data-patch-filter-btn]');
      try {{ localStorage.setItem('aiw_patch_filter', value); }} catch(e) {{}}
      var shown = 0;
      document.querySelectorAll('[data-patch-filter]').forEach(card => {{
        var status = card.getAttribute('data-patch-filter') || '';
        var match = value === 'all' || status === value;
        card.style.display = match ? '' : 'none';
        if (match) shown += 1;
      }});
      var empty = document.getElementById('patch-filter-empty');
      if (empty) empty.style.display = shown ? 'none' : '';
    }}
            async function rebuildContextIndex(event) {{
      const btn = event.currentTarget;
      const oldText = btn.innerText;
      btn.innerText = "Reconstruindo...";
      btn.disabled = true;
      try {{
        const res = await fetch('/api/context/rebuild?workspace={html.escape(active_workspace)}', {{method: 'POST'}});
        const data = await res.json();
        if(res.ok) {{
           location.reload();
        }} else {{
           alert("Erro: " + data.error);
        }}
      }} catch(e) {{
        alert("Erro de rede.");
      }}
      btn.innerText = oldText;
      btn.disabled = false;
    }}

    async function performSearch() {{
      const q = document.getElementById('search-input').value;
      try {{ localStorage.setItem('aiw_search_q', q); }} catch(e) {{}}
      if(q.length < 2) {{
          document.getElementById('search-results').style.display = 'none';
          document.getElementById('search-empty').style.display = 'none';
          return;
      }}
      const res = await fetch('/api/search?q=' + encodeURIComponent(q) + '&workspace={html.escape(active_workspace)}');
      const data = await res.json();
      const container = document.getElementById('search-results');
      const sourceLabel = document.getElementById('search-source');
      if (sourceLabel) sourceLabel.innerText = data.source === 'cache' ? 'Fonte: Cache' : 'Fonte: Varredura Direta';
      if(data.count === 0) {{
          container.style.display = 'none';
          document.getElementById('search-empty').style.display = 'block';
          return;
      }}
      container.style.display = 'grid';
      document.getElementById('search-empty').style.display = 'none';
      container.innerHTML = data.results.map(r => `
        <div class="card">
          <div class="card-title"><a href="${{r.url}}">${{r.title}}</a></div>
          <div class="card-meta"><span class="tag">${{r.type}}</span><span class="tag">${{r.path_label}}</span></div>
          <div class="card-summary">${{r.snippet}}</div>
        </div>
      `).join('');
    }}

    function restoreFilters() {{
      try {{
        const runF = localStorage.getItem('aiw_run_filter') || 'all';
        const patchF = localStorage.getItem('aiw_patch_filter') || 'all';
        const searchQ = localStorage.getItem('aiw_search_q') || '';
        const runBtn = document.querySelector(`[data-run-filter-btn="${{runF}}"]`);
        if(runBtn) filterRuns(runF, runBtn);
        const patchBtn = document.querySelector(`[data-patch-filter-btn="${{patchF}}"]`);
        if(patchBtn) filterPatches(patchF, patchBtn);
        if(searchQ) {{
            const searchInput = document.getElementById('search-input');
            if(searchInput) {{
                searchInput.value = searchQ;
                performSearch();
            }}
        }}
      }} catch(e) {{}}
    }}

    function clearFilters() {{
      try {{ localStorage.removeItem('aiw_run_filter'); }} catch(e) {{}}
      try {{ localStorage.removeItem('aiw_patch_filter'); }} catch(e) {{}}
      try {{ localStorage.removeItem('aiw_search_q'); }} catch(e) {{}}
      const runBtn = document.querySelector('[data-run-filter-btn="all"]');
      if(runBtn) filterRuns('all', runBtn);
      const patchBtn = document.querySelector('[data-patch-filter-btn="all"]');
      if(patchBtn) filterPatches('all', patchBtn);
      const searchInput = document.getElementById('search-input');
      if(searchInput) searchInput.value = '';
      document.getElementById('search-results').style.display = 'none';
      document.getElementById('search-empty').style.display = 'none';
    }}

    document.addEventListener('DOMContentLoaded', restoreFilters);

    document.querySelectorAll('[data-run-filter-btn]').forEach(btn => {{
      btn.addEventListener('click', () => filterRuns(btn.getAttribute('data-run-filter-btn'), btn));
    }});
    document.querySelectorAll('[data-patch-filter-btn]').forEach(btn => {{
      btn.addEventListener('click', () => filterPatches(btn.getAttribute('data-patch-filter-btn'), btn));
    }});
  </script>
</body>
</html>"""


def _is_relative_to(path: Path, root: Path) -> bool:
    try:
        path.relative_to(root)
        return True
    except ValueError:
        return False


def safe_run_dir(raw_path: str) -> Path | None:
    if not raw_path:
        return None

    if raw_path.startswith("/") or ".." in raw_path:
        return None

    allowed_roots = [(ROOT / ".aiw" / "runs").resolve()]
    scoped_root = (ROOT / ".aiw" / "workspaces" / active_workspace_id() / "runs").resolve()
    allowed_roots.insert(0, scoped_root)

    if not (raw_path.startswith(".aiw/runs/") or raw_path.startswith(".aiw/workspaces/")):
        return None

    run_dir = (ROOT / raw_path).resolve()
    if not any(_is_relative_to(run_dir, root) for root in allowed_roots):
        return None

    if not run_dir.exists() or not run_dir.is_dir():
        return None

    return run_dir


def resolve_run_ref(raw_ref: str) -> Path | None:
    run_ref = unquote(raw_ref or "").strip("/")
    if not run_ref or ".." in run_ref or run_ref.startswith("/"):
        return None
    if run_ref.startswith(".aiw/runs/"):
        return safe_run_dir(run_ref)
    if run_ref.startswith(".aiw/workspaces/"):
        return safe_run_dir(run_ref)

    runs_root = (ROOT / ".aiw" / "workspaces" / active_workspace_id() / "runs").resolve()
    run_dir = (runs_root / run_ref).resolve()
    try:
        run_dir.relative_to(runs_root)
    except ValueError:
        return None
    if not run_dir.exists() or not run_dir.is_dir():
        return None
    return run_dir


def read_text_file(path: Path, limit: int = 20000) -> str:
    if not path.exists() or not path.is_file():
        return ""

    text = path.read_text(encoding="utf-8", errors="replace")

    if len(text) > limit:
        return text[:limit] + "\n\n--- TRUNCATED ---\n"

    return text


def create_task_from_cockpit(title: str, output: str = "") -> tuple[bool, str]:
    title = (title or "").strip()
    output = (output or "").strip()

    if not title:
        return False, "task title is required"

    if output:
        if not output.startswith("docs/") or not output.endswith(".md") or ".." in output or output.startswith("/") or ".env" in output:
            return False, "invalid output path"
        cmd = [str(ROOT / "scripts" / "aiw-doc-task-create"), title, output]
    else:
        cmd = [str(ROOT / "scripts" / "aiw-task-create"), title]

    try:
        completed = subprocess.run(
            cmd,
            cwd=str(ROOT),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=30,
            check=False,
        )
    except Exception as exc:
        return False, f"task creation failed: {exc}"

    ok = completed.returncode == 0
    return ok, completed.stdout.strip()


def run_once_from_cockpit(llm_enabled: str = "1", model: str = "dev-gemini-fast") -> tuple[bool, str, str]:
    enabled = "1" if llm_enabled != "0" else "0"
    model = (model or "dev-gemini-fast").strip()

    allowed = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.:/")
    if not model or any(ch not in allowed for ch in model):
        return False, "invalid model", ""

    env = os.environ.copy()
    env["AIW_LLM_ENABLED"] = enabled
    env["AIW_MODEL"] = model
    env["AIW_WORKSPACE_ID"] = active_workspace_id()

    try:
        completed = subprocess.run(
            [str(ROOT / "scripts" / "aiw-runner-once")],
            cwd=str(ROOT),
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=300,
            check=False,
        )
    except Exception as exc:
        return False, f"runner failed: {exc}", ""

    output = completed.stdout.strip()
    run_dir = ""

    for line in output.splitlines():
        if line.startswith("RUN_DIR:"):
            run_dir = line.split(":", 1)[1].strip()
            try:
                run_dir = str(Path(run_dir).resolve().relative_to(ROOT))
            except Exception:
                pass

    ok = completed.returncode == 0 and bool(run_dir)
    return ok, output, run_dir


def run_agent_from_cockpit(model: str = "dev-coder", offline: bool = False, workspace_id: str | None = None) -> tuple[bool, str, str]:
    model = (model or "dev-coder").strip()

    allowed = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.:/")
    if not model or any(ch not in allowed for ch in model):
        return False, "invalid model", ""

    ws_id = active_workspace_id(workspace_id)
    ws = resolve_workspace(ws_id)
    if not ws or not ws.get("exists"):
        return False, "workspace not found or unavailable", ""

    env = os.environ.copy()
    env["AIW_MODEL"] = model
    env["AIW_ROOT"] = str(ROOT)
    env["AIW_WORKSPACE_ID"] = ws_id
    env["AIW_WORKSPACE_ROOT"] = ws["resolved_path"]
    env["AIW_SOURCE_ROOTS"] = ":".join((ws.get("profile") or {}).get("source_roots", []))
    env["AIW_USE_CONTEXT_PACK"] = "1"
    if offline:
        env["AIW_AGENT_OFFLINE"] = "1"

    try:
        completed = subprocess.run(
            [str(ROOT / "scripts" / "aiw-runner-agent")],
            cwd=str(ROOT),
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=300,
            check=False,
        )
    except Exception as exc:
        return False, f"runner failed: {exc}", ""

    output = completed.stdout.strip()
    run_dir = ""

    for line in output.splitlines():
        if line.startswith("RUN_DIR:"):
            run_dir = line.split(":", 1)[1].strip()
            try:
                run_dir = str(Path(run_dir).resolve().relative_to(ROOT))
            except Exception:
                pass

    ok = completed.returncode == 0 and bool(run_dir)
    return ok, output, run_dir


def run_action(action: str, run_path: str, reason: str = "") -> tuple[bool, str]:
    run_dir = safe_run_dir(run_path)

    if run_dir is None:
        return False, "invalid run path"

    rel = str(run_dir.relative_to(ROOT))

    if action == "approve":
        cmd = [str(ROOT / "scripts" / "aiw-run-approve"), rel]
    elif action == "reject":
        cmd = [str(ROOT / "scripts" / "aiw-run-reject"), rel, reason or "Rejected from AIW Local Cockpit."]
    else:
        return False, "invalid action"

    try:
        completed = subprocess.run(
            cmd,
            cwd=str(ROOT),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=30,
            check=False,
        )
    except Exception as exc:
        return False, f"action failed: {exc}"

    ok = completed.returncode == 0
    return ok, completed.stdout.strip()


def render_file_block(title: str, content: str) -> str:
    if not content:
        return f"""
        <div class="file-block muted">
          <div class="file-head"><h4>{html.escape(title)}</h4></div>
          <pre class="pre-empty">Arquivo ausente ou vazio.</pre>
        </div>
        """

    return f"""
    <div class="file-block">
      <div class="file-head"><h4>{html.escape(title)}</h4></div>
      <pre>{html.escape(sanitize_ui_text(content))}</pre>
    </div>
    """


def render_run_detail(run_dir: Path) -> str:
    rel = str(run_dir.relative_to(ROOT))
    status = read_json(run_dir / "status.json")

    status_label = status.get("status", "unknown")
    doc_status = status.get("doc_status", "-")
    llm_status = status.get("llm_status", "-")
    model = status.get("model", "-")
    generated_file = status.get("generated_file", "")
    run_workspace_id = str(status.get("workspace_id", "aiw"))
    run_workspace_name = str(status.get("workspace_name", run_workspace_id))
    run_workspace_root = str(status.get("workspace_root", ROOT))
    run_artifact_scope = str(status.get("artifact_scope", artifact_scope_label(run_dir, run_workspace_id)))

    # Objective from task.md
    task_text = read_text_file(run_dir / "task.md")
    objective = ""
    if task_text:
        for line in task_text.splitlines():
            if line.startswith("# "):
                objective = line[2:].strip()
                break
        if not objective:
            objective = task_text[:200].strip()

    # Result from summary.md
    result_text = read_text_file(run_dir / "summary.md", limit=4000)

    # Priority blocks
    objective_block = f"""
    <div class="priority-block">
      <h3>Objetivo</h3>
      <div class="objective-text">{html.escape(sanitize_ui_text(objective)) if objective else '<span style="color:var(--muted)">Não encontrado</span>'}</div>
    </div>
    """ if objective else ""

    context_used = ""
    ctx_json_file = run_dir / "context-used.json"
    if ctx_json_file.is_file():
        try:
            ctx_data = read_json(ctx_json_file)
            sources = ctx_data.get("sources", [])
            head = ctx_data.get("repo_head", "unknown")
            sources_html = "".join(f"<li>{html.escape(s.get('path', ''))} - <span style='color:var(--muted)'>{html.escape(s.get('reason', ''))}</span></li>" for s in sources)

            context_used = f"""
            <div class="priority-block" style="background:var(--panel2); border:1px solid var(--line);">
              <h3>Contexto usado pelo agente</h3>
              <div style="font-size:13px;margin-bottom:8px;">
                <strong>Status:</strong> Usado <br>
                <strong>HEAD do contexto:</strong> {html.escape(head)} <br>
                <strong>Fontes ({len(sources)}):</strong>
                <ul style="margin-top:4px;padding-left:20px;">
                  {sources_html}
                </ul>
              </div>
            </div>
            """
        except:
            pass

    result_block = f"""
    <div class="priority-block">
      <h3>Resultado</h3>
      <div class="result-text"><pre style="background:none;padding:0;font-size:13px">{html.escape(sanitize_ui_text(result_text))}</pre></div>
    </div>
    """ if result_text else ""

    file_block = ""
    if generated_file:
        file_block = f"""
        <div class="priority-block">
          <h3>Arquivo gerado</h3>
          <div class="card-doc" style="font-size:14px">→ {html.escape(generated_file)}</div>
        </div>
        """

    evidence = build_tool_evidence(run_dir)
    is_agent = evidence["mode"] in ("online", "offline")
    timeline_html = render_run_timeline_block(build_run_timeline(run_dir, evidence))
    tools_html = render_tool_evidence_block(evidence, rel)
    mode_str = "One-shot (Legado)"
    patches_html = ""

    if is_agent:
        mode_str = "Agent Offline" if evidence["mode"] == "offline" else "Agent (Tool Runtime)"

        patch_ids = []
        for t in evidence["tools"]:
            if t["name"] == "project_patch_preview" and t.get("patch_id"):
                patch_ids.append(t.get("patch_id"))

        if patch_ids:
            patches_list = ""
            for pid in patch_ids:
                pdata = patch_status_for_id(pid, run_workspace_id)
                if pdata:
                    p_path = pdata.get("path", "")
                    p_status = pdata.get("status", "")
                    p_reason = pdata.get("reason", "")
                    p_diff = pdata.get("diff", "")

                    apply_btn = ""
                    if p_status == "preview" and run_workspace_id == "aiw":
                        apply_btn = f'''<form method="post" action="/runner/patch/apply" style="display:inline"><input type="hidden" name="patch_id" value="{pid}"><input type="hidden" name="run_path" value="{rel}"><button class="btn btn-run" style="padding:4px 8px;font-size:12px" type="submit">Aplicar</button></form>'''
                    elif p_status == "applied":
                        apply_btn = f'''<form method="post" action="/runner/patch/rollback" style="display:inline"><input type="hidden" name="patch_id" value="{pid}"><input type="hidden" name="run_path" value="{rel}"><button class="btn btn-danger" style="padding:4px 8px;font-size:12px" type="submit">Rollback</button></form>'''
                    elif p_status == "preview":
                        apply_btn = '<span class="tag">No auto-apply</span>'

                    patches_list += f"""
                    <div style="border:1px solid var(--line);border-radius:12px;padding:12px;margin-bottom:8px;background:var(--panel2)">
                        <div style="display:flex;justify-content:space-between;margin-bottom:8px;align-items:center">
                            <strong style="color:var(--text)">{html.escape(p_path)}</strong>
                            <div>
                                <span class="tag status-{p_status}" style="margin-right:8px">{p_status}</span>
                                {apply_btn}
                            </div>
                        </div>
                        <div style="color:var(--muted);font-size:13px;margin-bottom:8px">Motivo: {html.escape(p_reason)}</div>
                        <details>
                            <summary style="cursor:pointer;color:var(--muted);font-size:12px">Ver diff técnico</summary>
                            <pre style="margin-top:8px;background:var(--bg);padding:8px;border-radius:4px;font-size:12px;overflow-x:auto;color:var(--text)">{html.escape(p_diff)}</pre>
                        </details>
                    </div>
                    """
            if patches_list:
                patches_html = f"""
                <div class="priority-block">
                  <h3>Alterações propostas</h3>
                  {patches_list}
                </div>
                """

    # Action bar
    next_action = ""
    if status_label == "review":
        next_action = "<strong>Ação recomendada:</strong> Revisar o resultado e aprovar ou rejeitar."
    elif status_label == "done":
        next_action = "<strong>Status:</strong> Aprovado. Nenhuma ação necessária."
    elif status_label == "failed":
        next_action = "<strong>Status:</strong> Falhou ou foi rejeitado."
    else:
        next_action = f"<strong>Status:</strong> {html.escape(status_label)}"

    action_bar = f"""
    <div class="action-bar">
      <form method="post" action="/action/approve">
        <input type="hidden" name="path" value="{html.escape(rel)}">
        <button class="btn btn-run" type="submit">Aprovar</button>
      </form>
      <form method="post" action="/action/reject" class="reject-inline">
        <input type="hidden" name="path" value="{html.escape(rel)}">
        <input class="input" name="reason" placeholder="Motivo da rejeição..." aria-label="Motivo">
        <button class="btn btn-danger" type="submit">Rejeitar com motivo</button>
      </form>
      <!-- Cancel button for running/queued runs -->
      <form method="post" action="/api/runs/{html.escape(rel)}/cancel" class="reject-inline">
        <button class="btn btn-danger" type="submit">Cancelar run</button>
      </form>

      <a class="btn btn-ghost" href="/">Voltar para review</a>
      <div style="margin-left:auto;color:var(--muted);font-size:12px;align-self:center">{next_action}</div>
    </div>
    """

    # Secondary files (priority order from spec)
    secondary_files = [
        "summary.md",
        "validation.log",
        "llm-output.md",
        "commands.log",
        "status.json",
        "task.md",
    ]
    file_blocks = ""
    for fname in secondary_files:
        file_blocks += render_file_block(fname, read_text_file(run_dir / fname))

    # Also show approval/rejection/error if present
    for fname in ["approval.md", "rejection.md", "llm-error.log"]:
        content = read_text_file(run_dir / fname)
        if content:
            file_blocks += render_file_block(fname, content)

    advanced_files_html = f"""
    <details style="margin-top:20px">
      <summary style="cursor:pointer;color:var(--muted);font-size:13px;padding:10px 0">Avançado: Ver evidências técnicas e arquivos brutos</summary>
      <div class="detail-files" style="margin-top:14px">
        {file_blocks}
      </div>
    </details>
    """

    return f"""<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>AIW Run Detail</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>{_CSS}</style>
</head>
<body>
  <div class="workspace">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <h1>AIW Cockpit</h1>
        <div class="version">Agent Workspace v2</div>
      </div>
      <nav class="nav-section">
        <a class="nav-item" href="/"><span class="icon">←</span>Voltar ao workspace</a>
      </nav>
      <div class="sidebar-footer">
        <span class="status-dot">●</span>Local only
      </div>
    </aside>
    <main class="main">
      <div class="detail-header">
        <a class="back" href="/">← Voltar ao workspace</a>
        <h2>Detalhe do run</h2>
        <div class="run-path">{html.escape(rel)}</div>
      </div>
      <div class="detail-meta-bar">
        <div class="meta-chip">
          <div class="chip-label">Modo</div>
          <div class="chip-value">{html.escape(mode_str)}</div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">Status</div>
          <div class="chip-value"><span class="tag status-{html.escape(str(status_label))}">{html.escape(str(status_label))}</span></div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">Modelo</div>
          <div class="chip-value">{html.escape(str(model))}</div>
        </div>
        <div class="meta-chip">
          <div class="chip-label">Doc</div>
          <div class="chip-value">{html.escape(str(doc_status))}</div>
        </div>
	        <div class="meta-chip">
	          <div class="chip-label">LLM</div>
	          <div class="chip-value">{html.escape(str(llm_status))}</div>
	        </div>
	        <div class="meta-chip">
	          <div class="chip-label">Workspace</div>
	          <div class="chip-value">{html.escape(run_workspace_name)} · {html.escape(run_workspace_id)}</div>
	        </div>
	        <div class="meta-chip">
	          <div class="chip-label">Workspace root</div>
	          <div class="chip-value">{html.escape(run_workspace_root)}</div>
	        </div>
	        <div class="meta-chip">
	          <div class="chip-label">Artifact scope</div>
	          <div class="chip-value">{html.escape(run_artifact_scope)}</div>
	        </div>
	      </div>

      {objective_block}
      {context_used}
      {result_block}
      {patches_html}
      {tools_html}
      {timeline_html}
      {file_block}
      {action_bar}

      {advanced_files_html}
    </main>
  </div>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print("%s - %s" % (self.address_string(), fmt % args))

    def send_json(self, payload: dict, status: int = 200):
        body = json.dumps(payload, ensure_ascii=False, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, body: str, status: int = 200):
        raw = body.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(raw)))
        self.end_headers()
        self.wfile.write(raw)

    def do_GET(self):
        path = urlparse(self.path).path

        # Existing GET handling remains unchanged – omitted for brevity
        # New endpoints for analysis artifacts
        if path.startswith("/api/runs/") and path.endswith("/diff-summary") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            diff_file = run_dir / "diff-summary.md"
            if diff_file.is_file():
                self.send_markdown(diff_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        if path.startswith("/api/runs/") and path.endswith("/handoff") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            handoff_file = run_dir / "handoff.md"
            if handoff_file.is_file():
                self.send_markdown(handoff_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        if path.startswith("/api/runs/") and path.endswith("/validator") and self.command == "GET":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            validator_file = run_dir / "validator.md"
            if validator_file.is_file():
                self.send_markdown(validator_file.read_text())
            else:
                self.send_json({"error": "artifact_missing"}, status=404)
            return
        if path.startswith("/api/runs/") and path.endswith("/evidence") and self.command == "GET":
            run_ref = path[len("/api/runs/"):-len("/evidence")]
            run_dir = resolve_run_ref(run_ref)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            self.send_json(build_tool_evidence(run_dir))
            return
        # fall through to existing logic

        if path.startswith("/api/search") and self.command == "GET":
            query = parse_qs(urlparse(self.path).query)
            q = query.get("q", [""])[0].strip()
            workspace_id = active_workspace_id(query.get("workspace", [""])[0])
            if len(q) < 2:
                self.send_json({"query": q, "workspace_id": workspace_id, "count": 0, "results": []})
                return

            q_lower = q.lower()
            target_root = workspace_root_for_context(workspace_id)
            idx = get_search_index(target_root, workspace_id)
            if idx:
                results = []
                for doc in idx.get("documents", []):
                    score = 0
                    if q_lower in doc.get("title", "").lower(): score += 5
                    if q_lower in doc.get("path", "").lower(): score += 3
                    if q_lower in doc.get("snippet", "").lower(): score += 1

                    if score > 0:
                        url = "/"
                        if doc["type"] == "run":
                            url = f"/run?path={quote(doc['path'])}"
                        results.append({
                            "type": doc["type"],
                            "title": doc["title"],
                            "path_label": doc.get("id", ""),
                            "snippet": doc.get("snippet", ""),
                            "url": url,
                            "score": score,
                            "workspace_id": doc.get("workspace_id", workspace_id),
                            "artifact_scope": doc.get("scope", doc.get("artifact_scope", "")),
                        })
                results.sort(key=lambda x: x["score"], reverse=True)
                results = results[:50]
                self.send_json({"query": q, "workspace_id": workspace_id, "count": len(results), "source": "cache", "results": results})
                return

            # Fallback to direct search
            results = local_lexical_search(q, workspace_id)
            self.send_json({"query": q, "workspace_id": workspace_id, "count": len(results), "source": "direct", "results": results})
            return

        if path == "/api/context/status":
            query = parse_qs(urlparse(self.path).query)
            workspace_id = active_workspace_id(query.get("workspace", [""])[0])
            self.send_json(context_health(workspace_id))
            return

        if path == "/api/context/pack":
            query = parse_qs(urlparse(self.path).query)
            workspace_id = active_workspace_id(query.get("workspace", [""])[0])
            pack = get_context_pack(workspace_root_for_context(workspace_id), workspace_id)
            if pack:
                self.send_json(pack)
            else:
                self.send_json({"error": "No context pack found"}, status=404)
            return

        if path == "/api/workspaces":
            self.send_json(workspaces_payload())
            return

        if path == "/api/workspaces/onboarding/validate":
            query = parse_qs(urlparse(self.path).query)
            raw_path = query.get("path", [""])[0]
            self.send_json(validate_workspace_path(raw_path))
            return

        if path.startswith("/api/workspaces/") and path.endswith("/health"):
            ws_id = path[len("/api/workspaces/"):-len("/health")].strip("/")
            health_payload = workspace_health(ws_id)
            self.send_json(health_payload, status=200 if health_payload.get("ok") else 404)
            return

        if path.startswith("/api/workspaces/") and path.endswith("/profile/validate"):
            ws_id = path[len("/api/workspaces/"):-len("/profile/validate")].strip("/")
            payload = validate_workspace_profile(ws_id)
            self.send_json(payload, status=200 if payload.get("ok") else 404)
            return

        if path.startswith("/api/workspaces/") and path.endswith("/execution-policy"):
            ws_id = path[len("/api/workspaces/"):-len("/execution-policy")].strip("/")
            payload = workspace_execution_policy(ws_id)
            self.send_json(payload, status=200 if payload.get("ok") else 404)
            return

        if path == "/api/git/status":
            query = parse_qs(urlparse(self.path).query)
            ws_id = query.get("workspace", ["aiw"])[0]
            payload = git_status_payload(ws_id)
            self.send_json(payload, status=200 if payload.get("ok") else 400)
            return

        if path == "/api/git/diff":
            query = parse_qs(urlparse(self.path).query)
            ws_id = query.get("workspace", ["aiw"])[0]
            payload = git_diff_payload(ws_id)
            self.send_json(payload, status=200 if payload.get("ok") else 400)
            return

        if path == "/":
            self.send_html(render_page())
            return

        if path == "/run":
            query = parse_qs(urlparse(self.path).query)
            raw_path = query.get("path", [""])[0]
            run_dir = safe_run_dir(raw_path)

            if run_dir is None:
                self.send_json({"error": "invalid_or_missing_run", "path": raw_path}, status=404)
                return

            self.send_html(render_run_detail(run_dir))
            return

        if path == "/api/status":
            self.send_json(status_payload())
            return

        if path == "/api/runs":
                self.send_json({"runs": list_runs(50)})
                return
        # Cancel endpoint: POST /api/runs/<run_path>/cancel
        if path.startswith("/api/runs/") and path.endswith("/cancel") and self.command == "POST":
            # Extract run_path between /api/runs/ and /cancel
            parts = path.split('/')
            if len(parts) >= 5:
                run_path = '/'.join(parts[3:-1])
            else:
                self.send_json({"error": "invalid_path"}, status=400)
                return
            run_dir = safe_run_dir(run_path)
            if run_dir is None:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            status_path = run_dir / "status.json"
            if not status_path.is_file():
                self.send_json({"error": "status_not_found"}, status=404)
                return
            import json, datetime
            data = json.loads(status_path.read_text())
            if data.get("status") in ("succeeded", "failed", "cancelled", "timed_out"):
                # already finished
                self.send_json({"run_id": run_path, "status": data.get("status")})
                return
            # set cancel flag and status
            data["cancel_requested"] = True
            data["status"] = "cancelled"
            now = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
            data["finished_at"] = now
            # attempt to kill pid if present
            pid = data.get("pid")
            if pid:
                try:
                    os.kill(pid, 9)
                except Exception:
                    pass
            status_path.write_text(json.dumps(data, indent=2))
            self.send_json({"run_id": run_path, "status": "cancelled"})
            return
        # Analysis endpoint: POST /api/runs/<run_path>/analyze
        if path.startswith("/api/runs/") and path.endswith("/analyze") and self.command == "POST":
            run_path = path.split('/')[-2]
            run_dir = safe_run_dir(run_path)
            if not run_dir:
                self.send_json({"error": "invalid_run"}, status=404)
                return
            status_path = run_dir / "status.json"
            if not status_path.is_file():
                self.send_json({"error": "status_not_found"}, status=404)
                return
            import json, datetime, subprocess, shlex, textwrap
            data = json.loads(status_path.read_text())
            if data.get("status") in ("queued", "running"):
                self.send_json({"error": "run_not_finished"}, status=409)
                return
            # ---- Diff Summary ----
            diff_summary_path = run_dir / "diff-summary.md"
            now = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
            sections = []
            sections.append("# Diff Summary\n")
            sections.append("## Run\n")
            sections.append(f"* Run ID: {data.get('id','')}")
            sections.append(f"* Title: {data.get('title','')}")
            sections.append(f"* Status: {data.get('status','')}")
            sections.append(f"* Created at: {data.get('created_at','')}")
            sections.append(f"* Finished at: {data.get('finished_at','')}")
            sections.append("\n## Git Status\n")
            gs = subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{gs}\n```")
            sections.append("\n## Diff Stat\n")
            ds = subprocess.run(["git", "diff", "--stat"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{ds}\n```")
            sections.append("\n## Diff Check\n")
            dc = subprocess.run(["git", "diff", "--check"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{dc if dc else 'No issues'}\n```")
            sections.append("\n## Changed Files\n")
            cf = subprocess.run(["git", "diff", "--name-only"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{cf if cf else 'No files changed'}\n```")
            sections.append("\n## Recent Commits\n")
            rc = subprocess.run(["git", "log", "--oneline", "-5"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            sections.append(f"```text\n{rc}\n```")
            diff_summary_path.write_text("\n".join(sections))
            # ---- Handoff ----
            handoff_path = run_dir / "handoff.md"
            mission_path = run_dir / "task.md"
            mission_content = mission_path.read_text() if mission_path.is_file() else ""
            handoff_md = textwrap.dedent(f"""
            # AIW Run Handoff

            ## Summary

            * Run ID: {data.get('id','')}
            * Title: {data.get('title','')}
            * Final status: {data.get('status','')}
            * Exit code: {data.get('exit_code','')}
            * Started: {data.get('started_at','')}
            * Finished: {data.get('finished_at','')}
            * Duration: {data.get('duration','')}

            ## Mission
            ```text
            {mission_content}
            ```

            ## Evidence
            * Metadata: {status_path.name}
            * Log: {run_dir / 'commands.log'}
            * Diff summary: {diff_summary_path.name}
            * Validation: {run_dir / 'validation.json'}

            ## Risks
            * Diff check issues: {'Yes' if dc else 'No'}
            * Working tree dirty after run: {'Yes' if subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip() else 'No'}
            """)
            handoff_path.write_text(handoff_md)
            # ---- Validator ----
            validator_path = run_dir / "validator.md"
            validation_json_path = run_dir / "validation.json"
            checks = []
            # metadata exists
            checks.append({"name": "metadata_exists", "status": "passed" if status_path.is_file() else "failed", "details": ""})
            # log exists
            log_path = run_dir / "commands.log"
            checks.append({"name": "log_exists", "status": "passed" if log_path.is_file() else "failed", "details": ""})
            # status final allowed
            allowed = {"queued","running","succeeded","failed","cancelled","timed_out"}
            final_status = data.get('status','')
            checks.append({"name": "final_status_allowed", "status": "passed" if final_status in allowed else "failed", "details": f"{final_status}"})
            # exit code check
            exit_code = data.get('exit_code')
            if final_status == 'succeeded':
                checks.append({"name": "exit_code_zero", "status": "passed" if exit_code == 0 else "failed", "details": f"{exit_code}"})
            # diff check
            diff_check_err = bool(dc)
            checks.append({"name": "git_diff_check", "status": "passed" if not diff_check_err else "failed", "details": dc if diff_check_err else ""})
            # reports not staged
            st = subprocess.run(["git", "status", "--short"], cwd=ROOT, capture_output=True, text=True).stdout.strip()
            reports_dirty = any(line.startswith('?? reports/') or line.startswith('A  reports/') for line in st.splitlines())
            checks.append({"name": "reports_not_staged", "status": "passed" if not reports_dirty else "failed", "details": ""})
            # secrets check (very simple) – look for .env patterns in changed files
            secret_leak = False
            for f in cf.splitlines():
                if f.endswith('.env'):
                    secret_leak = True
                    break
            checks.append({"name": "secrets_not_leaked", "status": "passed" if not secret_leak else "failed", "details": ""})
            # aggregate
            overall = "passed" if all(c['status']=='passed' for c in checks) else "failed"
            validation_json = {
                "run_id": data.get('id',''),
                "status": overall,
                "checks": checks,
                "recommended_action": "none" if overall=='passed' else "review"
            }
            validation_json_path.write_text(json.dumps(validation_json, indent=2))
            # validator.md human readable
            validator_md = "# Validator Report\n\n" + "\n".join([f"* {c['name']}: {c['status']}" for c in checks])
            validator_path.write_text(validator_md)
            # update metadata with artifact paths and validation status
            data.update({
                "diff_summary_path": str(diff_summary_path),
                "handoff_path": str(handoff_path),
                "validator_path": str(validator_path),
                "validation_path": str(validation_json_path),
                "validation_status": overall,
                "recommended_action": validation_json["recommended_action"]
            })
            status_path.write_text(json.dumps(data, indent=2))
            # respond
            self.send_json({"run_id": run_path, "analysis": "completed", "validation_status": overall})
            return
        # fall through to existing logic

    def do_POST(self):
        path = urlparse(self.path).path

        length = int(self.headers.get("Content-Length", "0") or "0")
        raw = self.rfile.read(length).decode("utf-8", errors="replace")

        content_type = self.headers.get("Content-Type", "")

        # JSON API endpoint for task creation
        if path == "/api/task/create":
            try:
                data = json.loads(raw) if raw else {}
            except Exception:
                self.send_json({"error": "invalid_json"}, status=400)
                return
            title = data.get("title", "")
            doc_output = data.get("output", data.get("doc_output", ""))
            model = data.get("model", "dev-gemini-fast")
            ok, output = create_task_from_cockpit(title, doc_output)
            if ok:
                self.send_json({"ok": True, "output": output, "model": model})
            else:
                self.send_json({"ok": False, "error": output}, status=400)
            return

        if path == "/api/context/rebuild":
            query = parse_qs(urlparse(self.path).query)
            workspace_id = active_workspace_id(query.get("workspace", [""])[0])
            res = rebuild_indexes(workspace_root_for_context(workspace_id), workspace_id)
            if res.get("ok"):
                self.send_json(res)
            else:
                self.send_json(res, status=400)
            return

        request_data = {}
        if content_type.startswith("application/json"):
            try:
                request_data = json.loads(raw) if raw else {}
            except Exception:
                self.send_json({"ok": False, "error": "invalid_json"}, status=400)
                return
        else:
            request_data = {k: v[0] if len(v) == 1 else v for k, v in parse_qs(raw).items()}

        if path == "/api/workspaces/active":
            ws_id = str(request_data.get("workspace_id", request_data.get("id", "")))
            res = write_active_workspace(ws_id)
            if content_type.startswith("application/json"):
                self.send_json(res, status=200 if res.get("ok") else 400)
            elif res.get("ok"):
                self.send_response(303)
                self.send_header("Location", "/")
                self.end_headers()
            else:
                self.send_json(res, status=400)
            return

        if path == "/api/workspaces":
            ws_id = str(request_data.get("id", request_data.get("workspace_id", ""))).strip()
            name = str(request_data.get("name", ws_id)).strip()
            raw_path = str(request_data.get("path", "")).strip()
            ws_type = str(request_data.get("type", "unknown")).strip()
            res = add_workspace(ws_id, name, raw_path, ws_type)
            if content_type.startswith("application/json"):
                self.send_json(res, status=200 if res.get("ok") else 400)
            elif res.get("ok"):
                self.send_response(303)
                self.send_header("Location", "/")
                self.end_headers()
            else:
                self.send_json(res, status=400)
            return

        if path == "/api/workspaces/remove":
            ws_id = str(request_data.get("workspace_id", request_data.get("id", ""))).strip()
            res = remove_workspace(ws_id)
            if content_type.startswith("application/json"):
                self.send_json(res, status=200 if res.get("ok") else 400)
            elif res.get("ok"):
                self.send_response(303)
                self.send_header("Location", "/")
                self.end_headers()
            else:
                self.send_json(res, status=400)
            return

        if path == "/api/git/branch/create":
            ws_id = str(request_data.get("workspace", "aiw"))
            branch = str(request_data.get("branch", "")).strip()
            workspace_path, err = workspace_path_or_error(ws_id)
            if err:
                self.send_json(err, status=400)
                return
            if not validate_branch_name(branch):
                self.send_json({"ok": False, "error": "invalid_branch_name"}, status=400)
                return
            proc = git_run(workspace_path, ["checkout", "-b", branch], timeout=20)
            res = {"ok": proc.returncode == 0, "stdout": proc.stdout, "stderr": proc.stderr, "branch": branch}
            self.send_json(res, status=200 if res["ok"] else 400)
            return

        if path == "/api/git/branch/checkout":
            ws_id = str(request_data.get("workspace", "aiw"))
            branch = str(request_data.get("branch", "")).strip()
            workspace_path, err = workspace_path_or_error(ws_id)
            if err:
                self.send_json(err, status=400)
                return
            if not validate_branch_name(branch):
                self.send_json({"ok": False, "error": "invalid_branch_name"}, status=400)
                return
            if git_status_files(workspace_path):
                self.send_json({"ok": False, "error": "dirty_worktree_checkout_blocked"}, status=409)
                return
            verify = git_run(workspace_path, ["rev-parse", "--verify", f"refs/heads/{branch}"], timeout=10)
            if verify.returncode != 0:
                self.send_json({"ok": False, "error": "branch_not_found"}, status=404)
                return
            proc = git_run(workspace_path, ["checkout", branch], timeout=20)
            res = {"ok": proc.returncode == 0, "stdout": proc.stdout, "stderr": proc.stderr, "branch": branch}
            self.send_json(res, status=200 if res["ok"] else 400)
            return

        if path == "/api/git/commit":
            ws_id = str(request_data.get("workspace", "aiw"))
            message = str(request_data.get("message", "")).strip()
            selected = request_data.get("files", [])
            if isinstance(selected, str):
                selected = [selected]
            workspace_path, err = workspace_path_or_error(ws_id)
            if err:
                self.send_json(err, status=400)
                return
            if not message or len(message) > 200:
                self.send_json({"ok": False, "error": "invalid_commit_message"}, status=400)
                return
            files, file_error = validate_git_file_selection(workspace_path, selected)
            if file_error:
                self.send_json({"ok": False, "error": file_error}, status=400)
                return
            add_proc = git_run(workspace_path, ["add", "--", *files], timeout=20)
            if add_proc.returncode != 0:
                self.send_json({"ok": False, "error": "git_add_failed", "stderr": add_proc.stderr}, status=400)
                return
            commit_proc = git_run(workspace_path, ["commit", "-m", message], timeout=30)
            res = {"ok": commit_proc.returncode == 0, "stdout": commit_proc.stdout, "stderr": commit_proc.stderr}
            self.send_json(res, status=200 if res["ok"] else 400)
            return

        # Form-encoded endpoints
        form = parse_qs(raw)

        run_path = form.get("path", [""])[0]
        reason = form.get("reason", [""])[0]

        if path == "/task/create":
            title = form.get("title", [""])[0]
            doc_output = form.get("output", [""])[0]
            ok, output = create_task_from_cockpit(title, doc_output)
            redirect = "/"
        elif path == "/runner/run-once":
            # AI is on by default — llm_enabled defaults to "1"
            llm_enabled = form.get("llm_enabled", ["1"])[0]
            model = form.get("model", ["dev-gemini-fast"])[0]
            ok, output, generated_run = run_once_from_cockpit(llm_enabled, model)
            redirect = f"/run?path={quote(generated_run)}" if generated_run else "/"
        elif path in ("/runner/run-agent", "/runner/run-agent-offline"):
            model = form.get("model", ["dev-coder"])[0]
            workspace_id = form.get("workspace_id", [""])[0]
            offline = path == "/runner/run-agent-offline"
            ok, output, generated_run = run_agent_from_cockpit(model, offline=offline, workspace_id=workspace_id)
            redirect = f"/run?path={quote(generated_run)}" if generated_run else "/"
        elif path == "/action/approve":
            ok, output = run_action("approve", run_path)
            redirect = f"/run?path={quote(run_path)}"
        elif path == "/action/reject":
            ok, output = run_action("reject", run_path, reason)
            redirect = f"/run?path={quote(run_path)}"
        elif path == "/runner/patch/apply":
            patch_id = form.get("patch_id", [""])[0]
            run_path = form.get("run_path", [""])[0]
            if patch_id:
                if str(ROOT) not in sys.path:
                    sys.path.insert(0, str(ROOT))
                from aiw_runtime.tools import project_patch_apply
                os.environ["AIW_WORKSPACE_ID"] = active_workspace_id()
                res = project_patch_apply(patch_id)
                ok = res.get("ok", False)
                output = res.get("error", "Unknown error")
            else:
                ok, output = False, "Missing patch_id"
            redirect = f"/run?path={quote(run_path)}" if run_path else "/"
        elif path == "/runner/patch/rollback":
            patch_id = form.get("patch_id", [""])[0]
            run_path = form.get("run_path", [""])[0]
            if patch_id:
                if str(ROOT) not in sys.path:
                    sys.path.insert(0, str(ROOT))
                from aiw_runtime.tools import project_patch_rollback
                os.environ["AIW_WORKSPACE_ID"] = active_workspace_id()
                res = project_patch_rollback(patch_id)
                ok = res.get("ok", False)
                output = res.get("error", "Unknown error")
            else:
                ok, output = False, "Missing patch_id"
            redirect = f"/run?path={quote(run_path)}" if run_path else "/"
        else:
            self.send_json({"error": "not_found", "path": path}, status=404)
            return

        if not ok:
            self.send_json({"error": "action_failed", "output": output}, status=400)
            return

        self.send_response(303)
        self.send_header("Location", redirect)
        self.end_headers()


class ThreadingTCPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
    allow_reuse_address = True


if __name__ == "__main__":
    if not ROOT.exists():
        raise SystemExit(f"AIW root not found: {ROOT}")

    url = f"http://{HOST}:{PORT}"
    print(f"AIW Local Cockpit running at {url}")
    print(f"ROOT: {ROOT}")
    print("Press Ctrl+C to stop")

    if OPEN_BROWSER:
        webbrowser.open(url)

    with ThreadingTCPServer((HOST, PORT), Handler) as httpd:
        httpd.serve_forever()
