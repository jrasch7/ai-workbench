#!/bin/bash
# AIW Agent Queue Foreground Dispatcher CLI

export PYTHONPATH="$PWD:$PYTHONPATH"

exec python3 - "$@" <<'PYTHON'
import sys
import argparse
import json
from pathlib import Path

# sys.argv fixed
sys.path.insert(0, str(Path.cwd()))

from aiw_workspace.agent_dispatcher import run_agent_dispatcher_once, run_agent_dispatcher_watch

def main():
    parser = argparse.ArgumentParser(description="AIW Agent Queue Foreground Dispatcher CLI")
    parser.add_argument("--workspace", required=True, help="Workspace ID")
    
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--once", action="store_true", help="Run once (default if neither specified)")
    group.add_argument("--watch", action="store_true", help="Run in foreground loop")
    
    parser.add_argument("--interval-seconds", type=int, default=30, help="Interval for watch mode")
    parser.add_argument("--dry-run", action="store_true", help="Run in dry-run mode (default)")
    parser.add_argument("--execute", action="store_true", help="Run execution (override dry-run)")
    parser.add_argument("--confirm-agent-dispatcher", action="store_true", help="Confirm execution in dispatcher")
    
    args = parser.parse_args()
    
    execute = False
    if args.execute:
        execute = True
        
    mode_once = not args.watch
    
    if mode_once:
        res = run_agent_dispatcher_once(
            workspace_id=args.workspace,
            execute=execute,
            confirm_dispatcher=args.confirm_agent_dispatcher
        )
        if res.get("ok"):
            print("Agent dispatcher (once) finished.")
            print(json.dumps(res.get("run", {}), indent=2))
            sys.exit(0)
        else:
            print(f"Agent dispatcher failed: {res.get('error')}", file=sys.stderr)
            sys.exit(1)
    else:
        res = run_agent_dispatcher_watch(
            workspace_id=args.workspace,
            interval_seconds=args.interval_seconds,
            execute=execute,
            confirm_dispatcher=args.confirm_agent_dispatcher
        )
        if res.get("ok"):
            print("Agent dispatcher (watch) stopped.")
            sys.exit(0)
        else:
            print(f"Agent dispatcher failed: {res.get('error')}", file=sys.stderr)
            sys.exit(1)

if __name__ == "__main__":
    main()
PYTHON
