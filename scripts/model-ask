#!/usr/bin/env bash
set -euo pipefail

AIW_ROOT="${AIW_ROOT:-$HOME/ai-workbench}"
MODEL="${1:-dev-coder}"

if [[ "$#" -gt 0 ]]; then
  shift
fi

cd "$AIW_ROOT"

if [[ ! -f .env ]]; then
  echo "ERROR: .env not found at $AIW_ROOT/.env"
  exit 1
fi

set -a
source .env
set +a

if [[ -z "${LITELLM_MASTER_KEY:-}" ]]; then
  echo "ERROR: LITELLM_MASTER_KEY missing or empty"
  exit 1
fi

if [[ "$#" -gt 0 ]]; then
  PROMPT="$*"
else
  PROMPT="$(cat)"
fi

if [[ -z "$PROMPT" ]]; then
  echo "ERROR: prompt is empty"
  exit 1
fi

for i in {1..60}; do
  if curl -fsS http://localhost:4000/v1/models -H "Authorization: Bearer $LITELLM_MASTER_KEY" >/dev/null 2>&1; then
    echo "OK: LiteLLM ready"
    break
  fi
  if [[ "$i" -eq 60 ]]; then
    echo "ERROR: LiteLLM did not become ready"
    exit 1
  fi
  echo "WAIT: LiteLLM not ready yet ($i/60)"
  sleep 2
done

REQUEST_FILE="/tmp/aiw-model-ask-request.json"
RESPONSE_FILE="/tmp/aiw-model-ask-response.json"

AIW_MODEL="$MODEL" AIW_PROMPT="$PROMPT" AIW_REQUEST_FILE="$REQUEST_FILE" python3 -c "import json, os; payload={\"model\":os.environ[\"AIW_MODEL\"],\"messages\":[{\"role\":\"user\",\"content\":os.environ[\"AIW_PROMPT\"]}],\"max_tokens\":2000}; open(os.environ[\"AIW_REQUEST_FILE\"],\"w\",encoding=\"utf-8\").write(json.dumps(payload,ensure_ascii=False))"

HTTP_CODE=$(curl --max-time 120 -sS -o "$RESPONSE_FILE" -w "%{http_code}" http://localhost:4000/v1/chat/completions -H "Authorization: Bearer $LITELLM_MASTER_KEY" -H "Content-Type: application/json" --data-binary @"$REQUEST_FILE" || true)

echo "HTTP: $HTTP_CODE"

if [[ ! -s "$RESPONSE_FILE" ]]; then
  echo "ERROR: empty response from LiteLLM"
  exit 1
fi

if [[ "$HTTP_CODE" != "200" ]]; then
  python3 -m json.tool "$RESPONSE_FILE" || cat "$RESPONSE_FILE"
  exit 1
fi

AIW_RESPONSE_FILE="$RESPONSE_FILE" python3 -c "import json, os; d=json.load(open(os.environ[\"AIW_RESPONSE_FILE\"],encoding=\"utf-8\")); print(d.get(\"choices\", [{}])[0].get(\"message\",{}).get(\"content\") or json.dumps(d, ensure_ascii=False, indent=2))"
