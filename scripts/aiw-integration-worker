#!/bin/bash
# AIW Integration Worker CLI

export PYTHONPATH="$PWD:$PYTHONPATH"

exec python3 - "$@" <<'PYTHON'
import sys
import argparse
import json
from pathlib import Path

# Fix sys.argv since we passed '-' as the script name
sys.argv = [sys.argv[0]] + sys.argv[2:]

# Ensure aiw_workspace is accessible
sys.path.insert(0, str(Path.cwd()))
from aiw_workspace.integration_worker import run_worker

def main():
    parser = argparse.ArgumentParser(description="AIW Integration Worker CLI")
    parser.add_argument("--workspace", required=True, help="Workspace ID")
    parser.add_argument("--item", required=True, help="Outbox Item ID")
    parser.add_argument("--dry-run", action="store_true", help="Run in dry-run mode (default)")
    parser.add_argument("--execute", action="store_true", help="Run execution (override dry-run)")
    parser.add_argument("--confirm-external-send", action="store_true", help="Confirm external network send")
    parser.add_argument("--pr-number", help="PR Number (required for execute)")
    
    args = parser.parse_args()
    
    dry_run = True
    if args.execute:
        dry_run = False
        
    result = run_worker(
        workspace_id=args.workspace,
        item_id=args.item,
        dry_run=dry_run,
        confirm_external_send=args.confirm_external_send,
        pr_number=args.pr_number
    )
    
    if result.get("ok"):
        print(f"Integration worker succeeded (dry_run={dry_run}).")
        if "attempt" in result:
            print(json.dumps(result["attempt"], indent=2))
        sys.exit(0)
    else:
        print(f"Integration worker failed: {result.get('error')}", file=sys.stderr)
        if "attempt" in result:
            attempt = result["attempt"]
            if attempt.get("policy_checked") and not attempt.get("policy_allowed"):
                print(f"POLICY BLOCKED: {attempt.get('policy_reason')}", file=sys.stderr)
            print(json.dumps(attempt, indent=2), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
PYTHON
