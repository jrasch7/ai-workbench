#!/usr/bin/env python3
"""Smoke test script for LangGraph engineering loop.

It runs the minimal graph defined in ``aiw_langgraph.graph`` and writes a
report to ``reports/langgraph-smoke``.

If the ``langgraph`` package is not installed, the script exits with a clear
message indicating how to install the dependency.
"""

import sys
import traceback
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

def main():
    try:
        import langgraph  # noqa: F401
    except ImportError:
        print("ERROR: Required dependency 'langgraph' is not installed.")
        print("Install with: pip install langgraph")
        sys.exit(1)

    try:
        from aiw_langgraph.graph import run
        from aiw_langgraph.reporting import write_report
    except ImportError as e:
        print("ERROR: Failed to import local AIW LangGraph modules.")
        print(f"Details: {e}")
        sys.exit(1)
    try:
        final_state = run()
        report_path = write_report(final_state)
        print(f"LangGraph smoke test completed. Report written to: {report_path}")
    except Exception:
        print("ERROR: Unexpected exception during execution:")
        traceback.print_exc()
        sys.exit(1)

if __name__ == "__main__":
    main()
