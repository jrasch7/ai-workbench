#!/usr/bin/env bash
set -euo pipefail

AIW_ROOT="${AIW_ROOT:-$HOME/ai-workbench}"

# AIW local monolith MVP shortcuts.
# These commands delegate to focused scripts and do not override existing service commands.
case "${1:-}" in
  local-status)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-status" "$@"
    ;;

  task)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-task-create" "$@"
    ;;

  doc-task)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-doc-task-create" "$@"
    ;;

  run-once|runner-once)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-runner-once" "$@"
    ;;

  watch|runner-watch)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-runner-watch" "$@"
    ;;

  runs|run-list)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-run-list" "$@"
    ;;

  show|run-show)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-run-show" "$@"
    ;;

  reject|run-reject)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-run-reject" "$@"
    ;;

  approve|run-approve)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-run-approve" "$@"
    ;;
  cockpit)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-cockpit" "$@"
    ;;

  daemon)
    shift
    cd "$AIW_ROOT"
    # Delegate to aiw/queue + persistent daemon (for 24/7 usage). Supports ws arg.
    python3 -c '
import sys, os
sys.path.insert(0, ".")
os.environ.setdefault("AIW_ROOT", ".")
ws = sys.argv[1] if len(sys.argv) > 1 else "aiw"
action = (sys.argv[2] if len(sys.argv) > 2 else "start").lower()
from aiw.queue import start_daemon_worker, stop_daemon_worker, list_daemon_workers, get_persistent_worker
from aiw.agent.iterative_loop import start_persistent_agent_daemon, list_running_daemons
print("==> aiw daemon for workspace:", ws, "action:", action)
if action in ("stop", "kill"):
    print(stop_daemon_worker(ws))
elif action == "list":
    print(list_daemon_workers(ws))
    print(list_running_daemons(ws))
else:
    print(start_daemon_worker(ws))
    print("daemons:", list_running_daemons(ws))
    print("tip: use AIW_PERSISTENT_MAX_ITERATIONS=0 for unlimited; resume via --run-id or cockpit")
' "$@"
    ;;

  doctor-local|local-doctor)
    shift
    cd "$AIW_ROOT"
    exec "$AIW_ROOT/scripts/aiw-doctor-local" "$@"
    ;;

  mission)
    shift
    cd "$AIW_ROOT"
    # Expanded mission (Step 5): support run, create, attach, get, list + approvals/queue
    python3 -c '
import sys, os, json
sys.path.insert(0, ".")
os.environ.setdefault("AIW_ROOT", ".")
args = sys.argv[1:]
ws = args[0] if args else "aiw"
action = args[1].lower() if len(args)>1 else "list"
from aiw import create_mission, list_missions, get_mission, attach_run_to_mission, attach_approval_to_mission, enqueue_mission_task, Mission
if action == "create":
    title = args[2] if len(args)>2 else "Missão CLI"
    task = args[3] if len(args)>3 else ""
    print(json.dumps(create_mission(ws, title, task), indent=2, ensure_ascii=False))
elif action == "run":
    # aiw mission run [ws] "title" "task" [--persistent]
    title = args[2] if len(args)>2 else "Missão via CLI run"
    task = args[3] if len(args)>3 else title
    m = create_mission(ws, title, task)
    mid = m.get("mission_id")
    print("[mission] created", mid)
    # queue tie-in + start persistent daemon run for the mission
    try:
        qres = enqueue_mission_task(mid, task, priority=5, workspace_id=ws)
        print("[mission] enqueued:", qres)
        from aiw.agent.iterative_loop import start_persistent_agent_daemon
        dres = start_persistent_agent_daemon(ws, task, execute=True, confirm=True, mission_id=mid, persistent=True)
        print("[mission] started daemon:", json.dumps(dres, indent=2, ensure_ascii=False))
        # attach if run_id present
        rid = dres.get("run_id")
        if rid:
            attach_run_to_mission(mid, rid, ws)
    except Exception as e:
        print("[mission run fallback attach only]", e)
    print(json.dumps(get_mission(mid, ws), indent=2, ensure_ascii=False))
elif action == "attach":
    mid = args[2] if len(args)>2 else ""
    rid = args[3] if len(args)>3 else ""
    print(attach_run_to_mission(mid, rid, ws))
elif action == "approve":
    mid = args[2] if len(args)>2 else ""
    ap = {"approval_id": "ap-"+__import__("uuid").uuid4().hex[:6], "status": "approved", "ts": __import__("datetime").datetime.utcnow().isoformat()+"Z"}
    print(attach_approval_to_mission(mid, ap, ws))
elif action == "get" or action == "status":
    mid = args[2] if len(args)>2 else ""
    m = get_mission(mid, ws)
    try:
        from aiw.mission import Mission
        if m:
            mm = Mission(m)
            print(json.dumps(mm.status(), indent=2, ensure_ascii=False))
        else:
            print(json.dumps(m, indent=2, ensure_ascii=False))
    except Exception:
        print(json.dumps(m, indent=2, ensure_ascii=False))
elif action == "runs":
    mid = args[2] if len(args)>2 else ""
    try:
        from aiw.mission import Mission
        m = get_mission(mid, ws)
        if m:
            mm = Mission(m)
            print(json.dumps(mm.list_runs(ws), indent=2, ensure_ascii=False))
        else:
            print("[]")
    except Exception as e:
        print(json.dumps({"error": str(e)}, indent=2))
elif action in ("bulk-approve", "approve-all"):
    # bulk approve pending for all active missions (CLI polish for prod UX)
    ms = list_missions(ws, limit=50)
    results = []
    for m in ms:
        mid = m.get("mission_id")
        approvs = m.get("approvals", []) or []
        pending = [a for a in approvs if (a.get("status") or "").lower() not in ("approved", "rejected")]
        if pending or (m.get("status") or "active") in ("active", "pending", "in_progress"):
            ap = {"approval_id": "ap-bulk-"+__import__("uuid").uuid4().hex[:6], "status": "approved", "ts": __import__("datetime").datetime.utcnow().isoformat()+"Z", "by": "cli-bulk"}
            ok = attach_approval_to_mission(mid, ap, ws)
            results.append({"mission_id": mid, "ok": ok})
    print(json.dumps({"bulk_approved": results}, indent=2, ensure_ascii=False))
else:
    ms = list_missions(ws, limit=10)
    print(json.dumps(ms, indent=2, ensure_ascii=False))
' "$@"
    ;;

esac

DEFAULT_WORKSPACE="${DEFAULT_WORKSPACE:-sandbox-test}"

cmd="${1:-help}"
workspace="${2:-$DEFAULT_WORKSPACE}"

log() {
  echo "==> $1"
}

ok() {
  echo "OK: $1"
}

warn() {
  echo "WARN: $1"
}

err() {
  echo "ERROR: $1"
}

cd_aiw_root() {
  cd "$AIW_ROOT"
}

load_env_if_present() {
  if [[ -f "$AIW_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$AIW_ROOT/.env"
    set +a
  fi
}

start_litellm() {
  cd_aiw_root
  log "Starting LiteLLM gateway..."
  docker compose up -d litellm
}

cleanup_openhands() {
  log "Stopping OpenHands containers if running..."
  docker rm -f openhands-app >/dev/null 2>&1 || true
  local agent_ids
  agent_ids="$(docker ps -aq --filter "name=oh-agent-server" || true)"
  if [[ -n "$agent_ids" ]]; then
    docker rm -f $agent_ids >/dev/null 2>&1 || true
  fi
}

prepare_workspace() {
  local target_dir="$1"
  mkdir -p "$target_dir"
  mkdir -p "$target_dir/conversations" "$target_dir/bash_events"
  chmod 777 "$target_dir/conversations" "$target_dir/bash_events" >/dev/null 2>&1 || true
  if [[ -d "$target_dir/.git/info" ]]; then
    touch "$target_dir/.git/info/exclude"
    grep -qxF "conversations/" "$target_dir/.git/info/exclude" || printf "\
conversations/\n" >> "$target_dir/.git/info/exclude"
    grep -qxF "bash_events/" "$target_dir/.git/info/exclude" || printf "bash_events/\n" >> "$target_dir/.git/info/exclude"
    grep -qxF "project/" "$target_dir/.git/info/exclude" || printf "project/\n" >> "$target_dir/.git/info/exclude"
  fi
}

start_openhands_here() {
  log "OpenHands will be available at: http://localhost:3000"
  log "Mounting workspace: $(pwd)"
  openhands serve --mount-cwd
}

run_workspace() {
  local target_dir="$1"
  start_litellm
  cleanup_openhands
  prepare_workspace "$target_dir"
  cd "$target_dir"
  start_openhands_here
}

run_doctor() {
  log "AI Workbench doctor"
  local failed=0


  if command -v docker >/dev/null 2>&1; then
    ok "docker binary found"
  else
    err "docker binary not found"
    failed=1
  fi

  if docker info >/dev/null 2>&1; then
    ok "docker daemon responding"
  else
    err "docker daemon not responding"
    failed=1
  fi

  if docker compose version >/dev/null 2>&1; then
    ok "docker compose available"
  else
    err "docker compose not available"
    failed=1
  fi

  if [[ -f "$AIW_ROOT/.env" ]]; then
    ok ".env found at $AIW_ROOT/.env"
    if grep -q '^LITELLM_MASTER_KEY=.' "$AIW_ROOT/.env"; then
      ok "LITELLM_MASTER_KEY configured"
    else
      err "LITELLM_MASTER_KEY missing or empty in .env"
      failed=1
    fi
  else
    err ".env not found at $AIW_ROOT/.env"
    failed=1
  fi

  if command -v openhands >/dev/null 2>&1; then
    ok "openhands binary found"
  else
    err "openhands binary not found"
    failed=1
  fi

  if docker ps --format '{{.Names}}' | grep -q '^aiw-litellm$'; then
    ok "LiteLLM container is running"
    load_env_if_present
    if [[ -n "${LITELLM_MASTER_KEY:-}" ]]; then
      if curl --max-time 15 -fsS http://localhost:4000/v1/models -H "Authorization: Bearer $LITELLM_MASTER_KEY" >/dev/null 2>&1; then
        ok "LiteLLM /v1/models responding"
      else
        warn "LiteLLM is running but /v1/models did not respond"
      fi
    else
      warn "Cannot test LiteLLM /v1/models because LITELLM_MASTER_KEY is not loaded"
    fi
  else
    warn "LiteLLM container is not running; run ./scripts/aiw gateway"
  fi

  if [[ "$failed" -eq 0 ]]; then
    log "Doctor finished without blocking errors."
  else
    log "Doctor found blocking errors."
    exit 1
  fi
}

case "$cmd" in
  start)
    run_workspace "$AIW_ROOT/workspaces/$workspace"
    ;;

  repo)
    run_workspace "$AIW_ROOT"
    ;;

  current)
    run_workspace "$(pwd)"
    ;;

  gateway)
    start_litellm
    log "LiteLLM access: http://localhost:4000"
    log "LiteLLM UI: http://localhost:4000/ui"
    ;;

  stop)
    cleanup_openhands
    log "Stopping AI Workbench services..."
    cd_aiw_root
    docker compose down
    ;;

  status)
    cd_aiw_root
    log "Docker compose services:"
    docker compose ps
    echo
    log "OpenHands containers:"
    docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}\t{{.Ports}}' | grep -E 'openhands|oh-agent|aiw-litellm' || true
    ;;

  logs)
    cd_aiw_root
    docker compose logs -f --tail=100 litellm
    ;;

  models)
    cd_aiw_root
    if [[ ! -f .env ]]; then
      err ".env not found at $AIW_ROOT/.env"
      exit 1
    fi
    load_env_if_present
    if [[ -z "${LITELLM_MASTER_KEY:-}" ]]; then
      err "LITELLM_MASTER_KEY missing or empty"
      exit 1
    fi
    curl --max-time 30 -sS http://localhost:4000/v1/models -H "Authorization: Bearer $LITELLM_MASTER_KEY" | python3 -m json.tool
    ;;

  doctor)
    run_doctor
    ;;

  smoke)
    cd_aiw_root
    ./scripts/model-smoke "${2:-dev-coder}"
    ;;

  matrix)
    cd_aiw_root
    shift || true
    ./scripts/model-matrix "$@"
    ;;

  help|*)
    cat <<'HELP'
AI Workbench

Usage:
  aiw start [workspace]   Start LiteLLM + OpenHands for an isolated workspace under ~/ai-workbench/workspaces
  aiw repo                Start LiteLLM + OpenHands mounted on ~/ai-workbench
  aiw current            Start LiteLLM + OpenHands mounted on the current directory
  aiw gateway             Start only LiteLLM gateway
  aiw stop                Stop OpenHands + LiteLLM
  aiw status              Show service status
  aiw logs                Follow LiteLLM logs
  aiw models              List models exposed by LiteLLM
  aiw doctor              Check local environment health
  aiw smoke [model]       Run chat smoke test through LiteLLM
  aiw matrix [models...]  Run smoke test matrix through LiteLLM

Examples:
  aiw start sandbox-test
  aiw repo
  aiw current
  aiw gateway
  aiw smoke dev-coder
  aiw matrix dev-openrouter-free dev-coder
  aiw stop
HELP
    ;;
  mission)
    cd "$AIW_ROOT"
    python3 -c '
import sys, os, json
sys.path.insert(0, ".")
os.environ.setdefault("AIW_ROOT", ".")
args = sys.argv[1:]
ws = args[0] if args else "aiw"
action = args[1].lower() if len(args)>1 else "list"
from aiw import create_mission, list_missions, get_mission, attach_run_to_mission, attach_approval_to_mission, enqueue_mission_task
if action == "create":
    title = args[2] if len(args)>2 else "Missão"
    task = args[3] if len(args)>3 else ""
    print(json.dumps(create_mission(ws, title, task), indent=2))
elif action == "run":
    title = args[2] if len(args)>2 else "Missão run"
    task = args[3] if len(args)>3 else title
    m = create_mission(ws, title, task); mid=m.get("mission_id")
    print("[mission] created", mid)
    try:
        print(enqueue_mission_task(mid, task, 5, ws))
        from aiw.agent.iterative_loop import start_persistent_agent_daemon
        print(start_persistent_agent_daemon(ws, task, execute=True, confirm=True, mission_id=mid, persistent=True))
    except Exception as e: print("start err", e)
    print(json.dumps(get_mission(mid, ws), indent=2))
elif action == "attach":
    print(attach_run_to_mission(args[2] if len(args)>2 else "", args[3] if len(args)>3 else "", ws))
elif action == "approve":
    print(attach_approval_to_mission(args[2] if len(args)>2 else "", {"approval_id":"ap-cli","status":"approved"}, ws))
elif action == "get":
    print(json.dumps(get_mission(args[2] if len(args)>2 else "", ws), indent=2))
else:
    print(json.dumps(list_missions(ws, 5), indent=2))
' "$@"
    ;;
esac
