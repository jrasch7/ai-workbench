#!/usr/bin/env bash
set -euo pipefail

AIW_ROOT="${AIW_ROOT:-$HOME/ai-workbench}"

MODELS=(
  dev-fast
  dev-balanced
  dev-large
  dev-coder
  dev-review
  dev-architect
  dev-fallback
)

cd "$AIW_ROOT"

echo "AIW LiteLLM operational alias pool smoke"
echo "root: $AIW_ROOT"
echo

for model in "${MODELS[@]}"; do
  echo "=== smoke: $model ==="
  ./scripts/model-smoke "$model"
  echo
done

echo "OK: LiteLLM operational alias pool smoke passed"
