#!/usr/bin/env bash
set -euo pipefail

AIW_ROOT="${AIW_ROOT:-$HOME/ai-workbench}"

MODELS=(
  dev-nvidia-nemotron
  dev-hf-kimi-code
  dev-hf-deepseek-v4-pro
  dev-hf-minimax-m3
)

cd "$AIW_ROOT"

echo "AIW LiteLLM model pool smoke"
echo "root: $AIW_ROOT"
echo

for model in "${MODELS[@]}"; do
  echo "=== smoke: $model ==="
  ./scripts/model-smoke "$model"
  echo
done

echo "OK: LiteLLM model pool smoke passed"
