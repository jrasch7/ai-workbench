#!/bin/bash
# AIW Agent Run Queue CLI

export PYTHONPATH="$PWD:$PYTHONPATH"

exec python3 - "$@" <<'PYTHON'
import sys
import argparse
import json
from pathlib import Path

# Fix sys.argv since we passed '-' as the script name
# sys.argv fixed

# Ensure aiw_workspace is accessible
sys.path.insert(0, str(Path.cwd()))
from aiw_workspace.agent_queue import (
    create_queue_item_from_inbox,
    update_queue_item_status,
    run_queue_item_offline,
    run_queue_item_llm,
    set_queue_dispatch
)

def main():
    parser = argparse.ArgumentParser(description="AIW Agent Queue CLI")
    parser.add_argument("--workspace", required=True, help="Workspace ID")
    parser.add_argument("--from-inbox", help="Create queue item from Inbox Item ID")
    parser.add_argument("--item", help="Queue Item ID to act upon")
    parser.add_argument("--mark-ready", action="store_true", help="Mark item ready")
    parser.add_argument("--run-offline", action="store_true", help="Run offline agent")
    parser.add_argument("--run-llm", action="store_true", help="Run LLM agent")
    parser.add_argument("--confirm-llm", action="store_true", help="Confirm LLM execution")
    parser.add_argument("--dry-run", action="store_true", help="Dry run LLM execution")
    parser.add_argument("--model", help="Model to use")
    parser.add_argument("--dismiss", action="store_true", help="Dismiss item")
    parser.add_argument("--confirm", action="store_true", help="Confirm action")
    parser.add_argument("--set-dispatch", action="store_true", help="Set dispatch metadata for foreground dispatcher")
    parser.add_argument("--dispatch-mode", choices=["offline", "llm"], help="Mode for dispatch (offline or llm)")
    
    args = parser.parse_args()
    
    if args.from_inbox:
        result = create_queue_item_from_inbox(args.workspace, args.from_inbox)
        if result.get("ok"):
            print("Queue item created successfully.")
            print(json.dumps(result["item"], indent=2))
            sys.exit(0)
        else:
            print(f"Failed to create queue item: {result.get('error')}", file=sys.stderr)
            sys.exit(1)
            
    if not args.item:
        print("Must provide either --from-inbox or --item", file=sys.stderr)
        sys.exit(1)
        
    if not args.confirm and (args.mark_ready or args.run_offline or args.dismiss or args.set_dispatch):
        print("Action requires --confirm", file=sys.stderr)
        sys.exit(1)
        
    if args.set_dispatch:
        if not args.dispatch_mode:
            print("Must provide --dispatch-mode with --set-dispatch", file=sys.stderr)
            sys.exit(1)
        result = set_queue_dispatch(
            workspace_id=args.workspace,
            queue_item_id=args.item,
            mode=args.dispatch_mode,
            model=args.model,
            confirm=args.confirm
        )
        if result.get("ok"):
            print("Queue dispatch configured successfully.")
            print(json.dumps(result.get("dispatch", {}), indent=2))
            sys.exit(0)
        else:
            print(f"Failed to configure dispatch: {result.get('error')}", file=sys.stderr)
            sys.exit(1)
        
    if args.mark_ready:
        result = update_queue_item_status(args.workspace, args.item, "ready", confirm=True)
        if result.get("ok"):
            print("Queue item marked ready.")
            sys.exit(0)
        else:
            print(f"Failed to mark ready: {result.get('error')}", file=sys.stderr)
            sys.exit(1)
            
    if args.dismiss:
        result = update_queue_item_status(args.workspace, args.item, "dismissed", confirm=True)
        if result.get("ok"):
            print("Queue item dismissed.")
            sys.exit(0)
        else:
            print(f"Failed to dismiss: {result.get('error')}", file=sys.stderr)
            sys.exit(1)
            
    if args.run_offline:
        result = run_queue_item_offline(args.workspace, args.item, confirm=True)
        if result.get("ok"):
            print("Queue item executed offline successfully.")
            sys.exit(0)
        else:
            print(f"Offline run failed: {result.get('error')}", file=sys.stderr)
            if "attempt" in result:
                print(json.dumps(result["attempt"], indent=2), file=sys.stderr)
            sys.exit(1)
            
    if args.run_llm:
        is_dry = args.dry_run
        if not args.confirm_llm:
            is_dry = True
            
        result = run_queue_item_llm(args.workspace, args.item, confirm_llm=args.confirm_llm, dry_run=is_dry, model=args.model)
        if result.get("ok"):
            print("Queue item LLM executed successfully.")
            print(json.dumps(result["attempt"], indent=2))
            sys.exit(0)
        else:
            print(f"LLM run failed: {result.get('error')}", file=sys.stderr)
            if "attempt" in result:
                print(json.dumps(result["attempt"], indent=2), file=sys.stderr)
            sys.exit(1)

if __name__ == "__main__":
    main()
PYTHON
