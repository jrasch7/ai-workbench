#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

echo "AIW_ROOT: $ROOT"
echo "BRANCH: $(git branch --show-current 2>/dev/null || echo unknown)"
echo "HEAD: $(git log -1 --oneline 2>/dev/null || echo unknown)"
echo

echo "GIT_STATUS:"
git status --short || true
echo

echo "QUEUES:"
for q in inbox running blocked review done failed; do
  count="$(find ".aiw/tasks/$q" -maxdepth 1 -type f -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
  printf "%-8s %s\n" "$q:" "$count"
done
echo

echo "RUNS:"
find .aiw/runs -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' '
